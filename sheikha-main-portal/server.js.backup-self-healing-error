// دالة حساب الأداء
function computeOrgPerformance(score) {
    const levels = internationalOrgsBlueprint.performanceLevels;
    for (let level = 5; level >= 1; level--) {
        const [min, max] = levels[level].range;
        if (score >= min && score <= max) {
            return { level, label: levels[level].label, color: levels[level].color };
        }
    }
    return { level: 1, label: 'ضعيف', color: '#d32f2f' };
}

