app.get(
    ['/api/stripe/restricted-key-permissions', '/api/stripe/restricted-key-permissions/extract'],
    (req, res) => {
        try {
            const permPath = path.join(__dirname, 'data', 'stripe-restricted-key-permissions.json');
            if (!fs.existsSync(permPath))
                return res.json({ success: false, message: 'الملف غير موجود' });
            const raw = JSON.parse(fs.readFileSync(permPath, 'utf8'));
            const format = (req.query.format || '').toLowerCase();
            const isExtractPath = req.path.endsWith('/extract');
            const extract =
                isExtractPath ||
                req.query.extract === '1' ||
                req.query.extract === 'true' ||
                format === 'extract';
            if (extract || format === 'flat' || format === 'csv') {
                const mainSelection = raw.mainSelection || {};
                const resourceTypes = raw.resourceTypes || {};
                const extracted = { main: [], sub: [], flat: [] };
                for (const [category, mainVal] of Object.entries(mainSelection)) {
                    if (mainVal !== 'none') extracted.main.push({ category, permission: mainVal });
                }
                for (const [category, items] of Object.entries(resourceTypes)) {
                    if (typeof items !== 'object') continue;
                    for (const [name, val] of Object.entries(items)) {
                        if (val !== 'none') {
                            extracted.sub.push({ category, resource: name, permission: val });
                            extracted.flat.push(`${category} > ${name}: ${val}`);
                        }
                    }
                }
                if (format === 'flat')
                    return res.type('text/plain; charset=utf-8').send(extracted.flat.join('\n'));
                if (format === 'csv') {
                    const csv = [
                        'category,resource,permission',
                        ...extracted.sub.map(s => `${s.category},${s.resource},${s.permission}`)
                    ].join('\n');
                    return res
                        .type('text/csv')
                        .set('Content-Disposition', 'attachment; filename=stripe-permissions.csv')
                        .send(csv);
                }
                return res.json({
                    success: true,
                    data: {
                        extracted,
                        count: { main: extracted.main.length, sub: extracted.sub.length }
                    },
                    timestamp: new Date().toISOString()
                });
            }
            res.json({ success: true, data: raw, timestamp: new Date().toISOString() });
        } catch (e) {
            res.json({ success: false, message: e.message });
        }
    }
);
