// 🛡️ API: تفعيل/تعطيل الإصلاح الذاتي
// POST /api/self-healing/toggle
// ────────────────────────────────────────────────────────────────────────────
app.post('/api/self-healing/toggle', (req, res) => {
    const { enabled } = req.body;
    
    if (typeof enabled !== 'boolean') {
        return res.status(400).json({
            success: false,
            error: 'invalid_input',
            message: 'يجب تحديد enabled كقيمة boolean',
            timestamp: new Date().toISOString()
        });
    }
    
    selfHealingSystem.enabled = enabled;
    
    res.json({
        success: true,
        data: {
            enabled: selfHealingSystem.enabled
        },
        message: enabled ? 'تم تفعيل الإصلاح الذاتي' : 'تم تعطيل الإصلاح الذاتي',
        timestamp: new Date().toISOString()
    });
});

// ────────────────────────────────────────────────────────────────────────────
// 🛡️ API: تسجيل تنبيه يدوياً (للاختبار أو التكامل)
// POST /api/self-healing/alert
// ────────────────────────────────────────────────────────────────────────────
app.post('/api/self-healing/alert', async (req, res) => {
    const { type, details } = req.body;
    
    if (!type) {
        return res.status(400).json({
            success: false,
            error: 'invalid_input',
            message: 'يجب تحديد نوع التنبيه (type)',
            timestamp: new Date().toISOString()
        });
    }
    
    const alert = selfHealingSystem.logAlert(type, details || {});
    
    // انتظار محاولة الإصلاح
    await new Promise(resolve => setTimeout(resolve, 500));
    
    // البحث عن التنبيه المحدّث
    const updatedAlert = selfHealingSystem.logs.find(l => l.id === alert.id);
    
    res.json({
        success: true,
        data: updatedAlert,
        message: 'تم تسجيل التنبيه ومحاولة الإصلاح',
        timestamp: new Date().toISOString()
    });
});

