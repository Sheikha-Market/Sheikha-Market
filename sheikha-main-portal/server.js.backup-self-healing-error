// 📁 IDE API: قائمة الملفات والمجلدات
app.get('/api/ide/files', (req, res) => {
    try {
        const targetPath = req.query.path || process.cwd();

        // حماية: منع الوصول لخارج workspace
        const workspacePath = path.resolve(process.cwd());
        const resolvedPath = path.resolve(targetPath);

        if (!resolvedPath.startsWith(workspacePath)) {
            return res.status(403).json({
                success: false,
                message: 'ممنوع الوصول لخارج workspace',
                timestamp: new Date().toISOString()
            });
        }

        // قراءة الملفات
        const items = fs.readdirSync(resolvedPath, { withFileTypes: true });
        const files = items.map(item => ({
            name: item.name,
            isDirectory: item.isDirectory(),
            path: path.join(resolvedPath, item.name).replace(workspacePath, ''),
            fullPath: path.join(resolvedPath, item.name),
            size: item.isFile() ? fs.statSync(path.join(resolvedPath, item.name)).size : null,
            modified: fs.statSync(path.join(resolvedPath, item.name)).mtime
        }));

        // فلترة الملفات المخفية والنظام
        const filteredFiles = files.filter(
            f =>
                !f.name.startsWith('.') &&
                f.name !== 'node_modules' &&
                f.name !== 'dist' &&
                f.name !== 'build'
        );

        res.json({
            success: true,
            data: {
                path: resolvedPath.replace(workspacePath, '') || '/',
                files: filteredFiles
            },
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في قراءة الملفات: ' + error.message,
            timestamp: new Date().toISOString()
        });
    }
});

