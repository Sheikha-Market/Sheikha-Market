// 🏗️ API: تقييم البنية التحتية
// POST /api/infrastructure/digital-physical-assessment
// Body: { organizationName, digitalScores: {...}, physicalScores: {...}, benchmarkTarget }
// ────────────────────────────────────────────────────────────────────────────
app.post('/api/infrastructure/digital-physical-assessment', express.json(), (req, res) => {
    const { organizationName, digitalScores, physicalScores, benchmarkTarget } = req.body;
    
    if (!organizationName || !digitalScores || !physicalScores) {
        return res.status(400).json({
            success: false,
            message: 'يجب تقديم اسم المنظمة ودرجات البنية الرقمية والمادية',
            timestamp: new Date().toISOString()
        });
    }
    
    // حساب متوسط الرقمي
    const digitalDomains = infrastructureAnalysisBlueprint.digitalInfrastructure.domains;
    let digitalTotal = 0;
    let digitalWeightSum = 0;
    
    for (const [key, domain] of Object.entries(digitalDomains)) {
        const score = clampScore(digitalScores[key] || 0);
        digitalTotal += score * domain.weight;
        digitalWeightSum += domain.weight;
    }
    const digitalOverall = digitalTotal / digitalWeightSum;
    
    // حساب متوسط المادي
    const physicalDomains = infrastructureAnalysisBlueprint.physicalInfrastructure.domains;
    let physicalTotal = 0;
    let physicalWeightSum = 0;
    
    for (const [key, domain] of Object.entries(physicalDomains)) {
        const score = clampScore(physicalScores[key] || 0);
        physicalTotal += score * domain.weight;
        physicalWeightSum += domain.weight;
    }
    const physicalOverall = physicalTotal / physicalWeightSum;
    
    // الدرجة الشاملة
    const overallScore = (digitalOverall * 0.5) + (physicalOverall * 0.5);
    
    // درجة التكامل (تقاس بمدى التقارب بين الرقمي والمادي)
    const integrationScore = 100 - Math.abs(digitalOverall - physicalOverall);
    
    // النضج
    const maturity = computeInfrastructureMaturity(overallScore);
    
    // المقارنة المرجعية
    const gaps = computeInfrastructureBenchmarkGaps(
        digitalOverall,
        physicalOverall,
        benchmarkTarget || 'globalLeaders'
    );
    
    // التوصيات
    const recommendations = buildInfrastructureRecommendations(
        digitalOverall,
        physicalOverall,
        integrationScore,
        maturity.level
