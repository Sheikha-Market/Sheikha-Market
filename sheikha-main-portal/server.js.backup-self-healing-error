// OAuth endpoint لكل مزود
['google', 'apple', 'microsoft', 'twitter', 'snapchat', 'instagram', 'tiktok'].forEach(provider => {
    app.get(`/api/auth/oauth/${provider}`, (req, res) => {
        const config = OAUTH_CONFIG[provider];
        const mode = req.query.mode || 'login';

        if (!config || !config.enabled) {
            // المزود غير مُعد — أرسل رسالة إعداد
            return res.json({
                success: false,
                setup: true,
                provider,
                name: config ? config.name : provider,
                message: `خدمة ${
                    config ? config.name : provider
                } تحتاج إعداد — أضف ${provider.toUpperCase()}_CLIENT_ID و ${provider.toUpperCase()}_CLIENT_SECRET في متغيرات البيئة`,
                instructions: {
                    step1: `أنشئ تطبيقاً في ${config ? config.name : provider} Developer Console`,
                    step2: `أضف Redirect URI: ${req.protocol}://${req.get(
                        'host'
                    )}/api/auth/oauth/${provider}/callback`,
                    step3: `ضع Client ID و Client Secret في ملف .env`
                }
            });
        }

        // بناء رابط OAuth حسب المزود
        const redirectUri = `${req.protocol}://${req.get(
            'host'
        )}/api/auth/oauth/${provider}/callback`;
        let authUrl = '';

        switch (provider) {
            case 'google':
                authUrl = `https://accounts.google.com/o/oauth2/v2/auth?client_id=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=openid%20email%20profile&state=${mode}&prompt=consent`;
                break;
            case 'apple':
                authUrl = `https://appleid.apple.com/auth/authorize?client_id=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=name%20email&state=${mode}&response_mode=form_post`;
                break;
            case 'microsoft':
                authUrl = `https://login.microsoftonline.com/common/oauth2/v2.0/authorize?client_id=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=openid%20email%20profile&state=${mode}`;
                break;
            case 'twitter':
                authUrl = `https://twitter.com/i/oauth2/authorize?client_id=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=tweet.read%20users.read%20offline.access&state=${mode}&code_challenge=challenge&code_challenge_method=plain`;
                break;
            case 'snapchat':
                authUrl = `https://accounts.snapchat.com/accounts/oauth2/auth?client_id=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=https://auth.snapchat.com/oauth2/api/user.display_name%20https://auth.snapchat.com/oauth2/api/user.bitmoji.avatar&state=${mode}`;
                break;
            case 'instagram':
                authUrl = `https://api.instagram.com/oauth/authorize?client_id=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=user_profile&state=${mode}`;
                break;
            case 'tiktok':
                authUrl = `https://www.tiktok.com/v2/auth/authorize/?client_key=${
                    config.clientId
                }&redirect_uri=${encodeURIComponent(
                    redirectUri
                )}&response_type=code&scope=user.info.basic&state=${mode}`;
                break;
        }

        res.json({ success: true, authUrl, provider, name: config.name });
    });

    // Callback لكل مزود
    app.get(`/api/auth/oauth/${provider}/callback`, async (req, res) => {
        const { code, state, error } = req.query;
        const mode = state || 'login';

        if (error || !code) {
            return res.redirect(
                `/%D8%AA%D8%B3%D8%AC%D9%8A%D9%84-%D8%A7%D9%84%D8%AF%D8%AE%D9%88%D9%84.html?error=${encodeURIComponent(
                    'فشل المصادقة عبر ' + (OAUTH_CONFIG[provider] || {}).name
                )}`
            );
        }

        try {
            // تبادل الكود بتوكن — يتطلب مكتبة HTTP حسب المزود
            // هنا نبني المنطق العام — كل مزود له token endpoint مختلف
            const config = OAUTH_CONFIG[provider];
            const redirectUri = `${req.protocol}://${req.get(
                'host'
            )}/api/auth/oauth/${provider}/callback`;

            // سيتم تطوير هذا الجزء عند ربط كل مزود فعلياً
            // حالياً: نسجل المحاولة ونعيد التوجيه
            console.log(
                `[OAuth] ${provider} callback received — code: ${
                    code ? 'yes' : 'no'
                }, mode: ${mode}`
            );

            // البحث عن مستخدم مربوط أو إنشاء جديد
            let user = USERS.find(u => u.oauthProviders && u.oauthProviders[provider]);

            if (!user && mode === 'register') {
                // إنشاء حساب جديد
                const id = 'U' + Date.now();
                user = {
                    id,
                    name: `مستخدم ${config.name}`,
                    phone: '',
                    email: '',
                    passwordHash: '',
                    storeName: '',
                    region: '',
                    role: 'user',
                    verified: true,
                    createdAt: new Date().toISOString(),
                    oauthProviders: { [provider]: { code, linkedAt: new Date().toISOString() } },
                    authMethods: [provider]
                };
                USERS.push(user);
                saveJSON(USERS_FILE, USERS);
            }

            if (user) {
                const token = jwt.sign({ userId: user.id, role: user.role || 'user' }, JWT_SECRET, {
                    expiresIn: '7d'
                });
                return res.redirect(
                    `/%D8%AA%D8%B3%D8%AC%D9%8A%D9%84-%D8%A7%D9%84%D8%AF%D8%AE%D9%88%D9%84.html?token=${token}&role=${
                        user.role || 'user'
                    }`
                );
            }

            // لا يوجد حساب — أعد للتسجيل
            return res.redirect(
                `/%D8%AA%D8%B3%D8%AC%D9%8A%D9%84-%D8%A7%D9%84%D8%AF%D8%AE%D9%88%D9%84.html?error=${encodeURIComponent(
                    'لا يوجد حساب مربوط بـ ' + config.name + ' — سجّل أولاً'
                )}`
            );
        } catch (e) {
            console.error(`[OAuth] ${provider} error:`, e.message);
            return res.redirect(
                `/%D8%AA%D8%B3%D8%AC%D9%8A%D9%84-%D8%A7%D9%84%D8%AF%D8%AE%D9%88%D9%84.html?error=${encodeURIComponent(
                    'خطأ في المصادقة'
                )}`
            );
        }
    });
});

