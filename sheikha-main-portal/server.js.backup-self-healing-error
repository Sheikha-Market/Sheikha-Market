function redactSensitiveValue(value) {
    if (typeof value !== 'string') return value;
    if (value.length > 24 && /key|secret|token|authorization|password|bearer/i.test(value)) {
        return value.slice(0, 6) + '...' + value.slice(-4);
    }
    return value;
}
function redactSensitiveObject(input) {
    if (Array.isArray(input)) return input.map(redactSensitiveObject);
    if (!input || typeof input !== 'object') return redactSensitiveValue(input);
    const out = {};
    for (const k of Object.keys(input)) {
        if (/key|secret|token|authorization|password/i.test(k)) {
            out[k] = '***redacted***';
        } else {
            out[k] = redactSensitiveObject(input[k]);
        }
    }
    return out;
}
