function loadNdjson(file) {
    try {
        if (!fs.existsSync(file)) return [];
        const raw = fs.readFileSync(file, 'utf8').trim();
        if (!raw) return [];
        return raw
            .split('\n')
            .map(line => {
                try {
                    return JSON.parse(line);
                } catch (_) {
                    return null;
                }
            })
            .filter(Boolean);
    } catch (_) {
        return [];
    }
}

function charitySummary(plan) {
    const goals = Array.isArray(plan?.goals) ? plan.goals : [];
    const totalTargetSAR = goals.reduce((sum, g) => sum + (Number(g.targetSAR) || 0), 0);
    const totalReceivedSAR = goals.reduce((sum, g) => sum + (Number(g.receivedSAR) || 0), 0);
    const progressPercent =
        totalTargetSAR > 0 ? Number(((totalReceivedSAR / totalTargetSAR) * 100).toFixed(2)) : 0;
    return {
        totalTargetSAR,
        totalReceivedSAR,
        remainingSAR: Math.max(totalTargetSAR - totalReceivedSAR, 0),
        progressPercent,
        goalsCount: goals.length,
        completedGoals: goals.filter(
            g => (Number(g.receivedSAR) || 0) >= (Number(g.targetSAR) || 0)
        ).length
    };
}

