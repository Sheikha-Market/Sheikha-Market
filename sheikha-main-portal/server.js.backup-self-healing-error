app.get('/api/plants/all', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    res.json({
        success: true,
        data: plantKnowledgeEngine.getAllPlants(),
        timestamp: new Date().toISOString()
    });
});
app.get('/api/plants/type/:typeId', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    const typeId = req.params.typeId || '';
    res.json({
        success: true,
        data: plantKnowledgeEngine.getPlantsByType(typeId),
        typeId,
        timestamp: new Date().toISOString()
    });
});
app.get('/api/plants/growth/:speed', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    const speed = req.params.speed || '';
    res.json({
        success: true,
        data: plantKnowledgeEngine.getPlantsByGrowthSpeed(speed),
        speed,
        timestamp: new Date().toISOString()
    });
});
app.get('/api/plants/region/:region', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    const region = req.params.region || '';
    res.json({
        success: true,
        data: plantKnowledgeEngine.getPlantsByRegion(region),
        region,
        timestamp: new Date().toISOString()
    });
});
app.get('/api/plants/search', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    const q = req.query.q || req.query.query || '';
    res.json({
        success: true,
        data: plantKnowledgeEngine.search(q),
        query: q,
        timestamp: new Date().toISOString()
    });
});
app.get('/api/plants/instant-results', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    const startMode = String(req.query.startMode || 'ready_seedling');
    const region = String(req.query.region || '');
    const maxDays = Number(req.query.maxDays || 120);
    const plan = plantKnowledgeEngine.getQuickFruitPlan({ startMode, region, maxDays });
    res.json({
        success: true,
        data: plan,
        message: 'تم تفعيل المسار الفوري للحصول على نتائج مثمرة بجودة عالية.',
        timestamp: new Date().toISOString()
    });
});
app.get('/api/plants/:idOrName', (req, res) => {
    if (!plantKnowledgeEngine) return res.json({ success: false });
    const idOrName = req.params.idOrName || '';
    const plant = plantKnowledgeEngine.getPlantDetails(idOrName);
    if (!plant) return res.status(404).json({ success: false, message: 'نبات غير موجود' });
    res.json({ success: true, data: plant, timestamp: new Date().toISOString() });
});

