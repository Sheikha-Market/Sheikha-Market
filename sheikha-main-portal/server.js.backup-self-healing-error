// ─── تحليل السياق من السؤال ─────────────────────────────────────────────────────
function detectContext(message) {
    const lower = message.toLowerCase();
    // بحث علمي
    if (
        lower.includes('بحث') ||
        lower.includes('دراسة') ||
        lower.includes('ورقة علمية') ||
        lower.includes('أكاديمي') ||
        lower.includes('باحث') ||
        lower.includes('مختبر')
    )
        return 'research';
    // أسعار
    if (
        lower.includes('سعر') ||
        lower.includes('أسعار') ||
        lower.includes('تسعير') ||
        lower.includes('كم يكلف') ||
        lower.includes('ثمن')
    )
        return 'pricing';
    // نقل ولوجستيات
    if (
        lower.includes('نقل') ||
        lower.includes('شحن') ||
        lower.includes('توصيل') ||
        lower.includes('لوجستي')
    )
        return 'logistics';
    // سلاسل الإمداد
    if (
        lower.includes('سلسلة') ||
        lower.includes('توريد') ||
        lower.includes('إمداد') ||
        lower.includes('scm')
    )
        return 'scm';
    // نظام ERP
    if (
        lower.includes('erp') ||
        lower.includes('مخزون') ||
        lower.includes('لوحة التحكم') ||
        lower.includes('dashboard')
    )
        return 'erp';
    // بيئة واستدامة
    if (
        lower.includes('بيئة') ||
        lower.includes('تدوير') ||
        lower.includes('أخضر') ||
        lower.includes('استدامة') ||
        lower.includes('co2')
    )
        return 'environment';
    // أسئلة عن المنظومة
    if (
        lower.includes('شيخة') ||
        lower.includes('المنظومة') ||
        lower.includes('النظام') ||
        lower.includes('كيف أبدأ') ||
        lower.includes('كيف استخدم')
    )
        return 'general';
    return 'general';
}

// ─── بناء السياق الكامل ─────────────────────────────────────────────────────────
function buildFullContext(message, user = null) {
    const context = detectContext(message);
    let systemPrompt = SHEIKHA_SYSTEM_PROMPT;

    if (context !== 'general' && CONTEXT_PROMPTS[context]) {
        systemPrompt += '\n\n## سياق متخصص:\n' + CONTEXT_PROMPTS[context];
    }

    if (user) {
        systemPrompt += `\n\n## معلومات المستخدم:
- الاسم: ${user.name || user.storeName || 'غير محدد'}
- نوع الحساب: ${user.role || 'تاجر'}
- صلاحياته محدودة بمتجره ومنتجاته فقط`;
    }

    return systemPrompt;
}
// ─── استدعاء Claude Opus 4.6 ─────────────────────────────────────────────────────
// 🧠 أقوى نموذج ذكاء اصطناعي في العالم (5 فبراير 2026)
// ✨ تفكير تكيفي | سياق 1M توكن | ضغط السياق | فرق وكلاء
async function callClaudeChat(messages, maxTokens = 8192, options = {}) {
    if (!ANTHROPIC_API_KEY) return { error: 'CLAUDE_NOT_CONFIGURED' };

    // تحويل الرسائل من صيغة OpenAI إلى صيغة Anthropic
    const systemMsg = messages.find(m => m.role === 'system');
    const chatMessages = messages
        .filter(m => m.role !== 'system')
        .map(m => ({
            role: m.role === 'assistant' ? 'assistant' : 'user',
            content: m.content
        }));

    const body = {
        model: ANTHROPIC_MODEL,
        max_tokens: maxTokens,
        system: systemMsg?.content || '',
        messages: chatMessages
    };

    // ─── تفعيل التفكير التكيفي (Adaptive Thinking) لـ Opus 4.6 ──────
    if (options.enableThinking && CLAUDE_FEATURES.adaptiveThinking) {
        body.thinking = {
            type: 'enabled',
            budget_tokens: options.thinkingBudget || 8192
        };
        body.max_tokens = maxTokens + (options.thinkingBudget || 8192);
    }

    try {
        const res = await fetch(ANTHROPIC_BASE_URL + '/messages', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-api-key': ANTHROPIC_API_KEY,
                'anthropic-version': ANTHROPIC_VERSION
            },
            body: JSON.stringify(body)
        });

        if (!res.ok) {
            const t = await res.text();
            return { error: 'CLAUDE_ERROR', status: res.status, detail: t.slice(0, 200) };
        }

        const data = await res.json();

        // استخراج الرد والتفكير (Opus 4.6 يدعم كتل التفكير)
        let reply = '';
        let thinking = null;

        if (data.content) {
            for (const block of data.content) {
                if (block.type === 'thinking') {
                    thinking = block.thinking;
                } else if (block.type === 'text') {
                    reply = block.text;
                }
            }
        }

        if (!reply) reply = data.content?.[0]?.text || '';

        return {
            reply,
            thinking,
            usage: data.usage,
            model: ANTHROPIC_MODEL,
            provider: 'anthropic-opus-4.6'
        };
    } catch (e) {
        return { error: 'CLAUDE_NETWORK_ERROR', detail: e.message };
    }
}

// ─── استدعاء Humain ALLaM (هيوماين السعودي — PIF) ───────────────────────────────────
// شراكات: AWS، NVIDIA، AMD | نموذج عربي عبر Hugging Face Inference API
// حماية: لا ضرر ولا ضرار | الملكية الفكرية: استخدام نموذج Humain الرسمي على HF
async function callHumainChat(messages, maxTokens = 2048, temperature = 0.6, options = {}) {
    if (!HUMAIN_HF_API_KEY) return { error: 'HUMAIN_NOT_CONFIGURED' };
    const lastUser = messages.filter(m => m.role === 'user').pop();
    const sys = messages.find(m => m.role === 'system');
    const prompt = sys
        ? `${(sys.content || '').slice(0, 2000)}\n\n${lastUser?.content || ''}`
        : lastUser?.content || '';
    if (!prompt.trim()) return { error: 'HUMAIN_EMPTY_PROMPT' };
    try {
        const res = await fetch(`${HUMAIN_BASE_URL}/models/${HUMAIN_MODEL}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                Authorization: 'Bearer ' + HUMAIN_HF_API_KEY
            },
            body: JSON.stringify({
                inputs: prompt,
                parameters: {
                    max_new_tokens: Math.min(maxTokens, 2048),
                    temperature: Math.max(0.1, Math.min(1, temperature)),
                    return_full_text: false,
                    do_sample: true
                }
            })
        });
        if (!res.ok) {
            const t = await res.text();
            if (res.status === 503)
                return { error: 'HUMAIN_LOADING', detail: 'النموذج قيد التحميل — حاول لاحقاً' };
            if (res.status === 429)
                return { error: 'HUMAIN_RATE_LIMIT', detail: 'تجاوز الحد — انتظر قليلاً' };
            return { error: 'HUMAIN_ERROR', status: res.status, detail: (t || '').slice(0, 150) };
        }
        const data = await res.json();
        const out = Array.isArray(data) ? data[0] : data;
        const reply = (out?.generated_text || out?.generated || '').trim();
        return reply
            ? { reply, model: HUMAIN_MODEL, provider: 'humain-allam' }
            : { error: 'HUMAIN_EMPTY_RESPONSE' };
    } catch (e) {
        return { error: 'HUMAIN_NETWORK_ERROR', detail: e.message };
    }
}

// ─── استدعاء OpenAI مع Fallback ─────────────────────────────────────────────────────
// الهدف: "أفضل نموذج يعمل دائماً" حتى لو تغيّر اسم النموذج/الواجهة.
// Fallback chain: configured → gpt-5.4 → gpt-5.3 → gpt-5.2 → gpt-4o → gpt-4o-mini
const OPENAI_FALLBACK_MODELS = ['gpt-5.4', 'gpt-5.3', 'gpt-5.2', 'gpt-4o', 'gpt-4o-mini'];
function buildModelFallbackChain(primaryModel) {
    const primary = (primaryModel || '').trim();
    const uniq = new Set();
    const out = [];
    const push = m => {
        const mm = String(m || '').trim();
        if (!mm) return;
        if (uniq.has(mm)) return;
        uniq.add(mm);
        out.push(mm);
    };
    // Allow "auto" to mean "try our full chain"
    if (primary && primary.toLowerCase() !== 'auto' && primary.toLowerCase() !== 'latest') {
        push(primary);
    }
    OPENAI_FALLBACK_MODELS.forEach(push);
    return out;
}

async function callOpenAIChat(messages, maxTokens = 800, temperature = 0.5, options = {}) {
    if (!OPENAI_API_KEY) {
        return { error: 'AI_NOT_CONFIGURED' };
    }

    // Try models in order until one works
    const modelsToTry = options.forceModel
        ? [options.forceModel]
        : buildModelFallbackChain(OPENAI_MODEL);

    for (const model of modelsToTry) {
        // GPT-5 / o1 models use max_completion_tokens instead of max_tokens
        const isNewModel =
            model.startsWith('gpt-5') || model.startsWith('o1') || model.startsWith('o3');

        const body = {
            model: model,
            messages
        };

        // Handle token parameter naming based on model
        if (isNewModel) {
            body.max_completion_tokens = Math.min(maxTokens, 4000);
            // GPT-5 / o1 doesn't support temperature
        } else {
            body.max_tokens = Math.min(maxTokens, 4000);
            body.temperature = temperature;
        }

        // ميزات GPT-5 الجديدة (فقط للنماذج التي تدعمها)
        if (isNewModel && options.reasoning_effort) {
            body.reasoning_effort = options.reasoning_effort;
        }
        if (isNewModel && options.verbosity) {
            body.verbosity = options.verbosity;
        }

        // Prefer AI_LLM_BASE_URL so this can work with proxies/gateways.
        const url = AI_LLM_BASE_URL + '/chat/completions';
        try {
            const res = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: 'Bearer ' + OPENAI_API_KEY
                },
                body: JSON.stringify(body)
            });

            if (!res.ok) {
                const t = await res.text();
                // Common server-side debug (no secrets)
                console.warn(
                    '[AI] OpenAI request failed',
                    JSON.stringify({
                        status: res.status,
                        model,
                        isNewModel,
                        detail: String(t || '').slice(0, 200)
                    })
                );
                // If model not found, try next model
                if (res.status === 404 || t.includes('does not exist') || t.includes('not found')) {
                    console.log(`[AI] Model ${model} not available, trying next...`);
                    continue;
                }
                // If request schema unsupported for this model/endpoints, try next model.
                if (
                    res.status === 400 &&
                    (t.includes('max_completion_tokens') ||
                        t.includes('reasoning_effort') ||
                        t.includes('verbosity') ||
                        t.includes('Unknown parameter') ||
                        t.includes('Unrecognized request argument') ||
                        t.includes('invalid_request_error'))
                ) {
                    console.log(`[AI] Model ${model} rejected request schema, trying next...`);
                    continue;
                }
                // Check for billing/quota issues
                if (res.status === 429 || t.includes('quota') || t.includes('billing')) {
                    return {
                        error: 'AI_QUOTA_EXCEEDED',
                        status: res.status,
                        detail: 'الرصيد منتهي في OpenAI. يرجى شحن الحساب.'
                    };
                }
                return { error: 'LLM_ERROR', status: res.status, detail: t.slice(0, 200) };
            }

            const data = await res.json();
            const choice = data.choices && data.choices[0];
            const reply =
                choice && choice.message && choice.message.content
                    ? choice.message.content.trim()
                    : '';

            // Log which model actually worked
            if (model !== OPENAI_MODEL) {
                console.log(`[AI] ✓ Using fallback model: ${model}`);
            }

            return {
                reply,
                usage: data.usage,
                model: model, // Return actual model used
                provider: 'openai',
                reasoning: choice?.message?.reasoning
            };
        } catch (e) {
            continue;
        }
    }

    // All models failed
    return { error: 'LLM_ALL_MODELS_FAILED', detail: 'تعذر الاتصال بأي نموذج AI' };
}

// ─── NVIDIA NIM — استدعاء نماذج Llama/Mistral عبر API موحد مع OpenAI ─────────────
async function callNvidiaNIMChat(messages, maxTokens = 800, temperature = 0.5, options = {}) {
    if (!NVIDIA_API_KEY || NVIDIA_API_KEY.length < 10) return { error: 'NVIDIA_NOT_CONFIGURED' };
    const model = options.forceModel || NVIDIA_NIM_MODEL;
    try {
        const res = await fetch(NVIDIA_NIM_BASE + '/chat/completions', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                Authorization: 'Bearer ' + NVIDIA_API_KEY
            },
            body: JSON.stringify({
                model,
                messages,
                max_tokens: Math.min(maxTokens, 4096),
                temperature: Math.min(Math.max(temperature, 0), 1)
            })
        });
        if (!res.ok) {
            const t = await res.text();
            console.warn('[AI] NVIDIA NIM request failed', res.status, String(t).slice(0, 150));
            return { error: 'LLM_ERROR', status: res.status, detail: t.slice(0, 200) };
        }
        const data = await res.json();
        const choice = data.choices && data.choices[0];
        const reply =
            choice && choice.message && choice.message.content ? choice.message.content.trim() : '';
        return { reply, usage: data.usage, model, provider: 'nvidia-nim' };
    } catch (e) {
        return { error: 'LLM_ERROR', detail: e.message };
    }
}

// ─── استدعاء LLM الذكي (يختار الأفضل تلقائياً) ─────────────────────────────────────
async function callLLMChat(messages, maxTokens = 800, temperature = 0.5, options = {}) {
    const isDevelopment =
        options.mode === 'development' ||
        messages.some(
            m =>
                m.content?.includes('كود') ||
                m.content?.includes('برمج') ||
                m.content?.includes('تطوير')
        );
    const lastMsg = messages.filter(m => m.role === 'user').pop()?.content || '';
    const isArabic =
        /[\u0600-\u06FF]/.test(lastMsg) && (lastMsg.match(/[\u0600-\u06FF]/g) || []).length > 3;
    const nvidiaFirst = options.mode === 'nvidia' || AI_MODE === 'nvidia' || NVIDIA_NIM_PRIORITY;

    // ١. للتطوير والبرمجة: Claude Opus 4.6
    if (isDevelopment && ANTHROPIC_API_KEY) {
        const result = await callClaudeChat(messages, maxTokens, options);
        if (!result.error) return result;
    }

    // ٢. للمحادثات العربية: Humain ALLaM (هيوماين السعودي — PIF) — أولوية وطنية
    if (isArabic && HUMAIN_HF_API_KEY) {
        const result = await callHumainChat(messages, maxTokens, temperature, options);
        if (!result.error) return result;
    }

    // ٣. أولوية NVIDIA (عند التفعيل): استخدام NIM أولاً ثم fallback المعتاد
    if (nvidiaFirst && NVIDIA_API_KEY && NVIDIA_API_KEY.length > 10) {
        const result = await callNvidiaNIMChat(messages, maxTokens, temperature, options);
        if (!result.error) return result;
    }

    // ٤. للمحادثات العامة: GPT
    if (OPENAI_API_KEY) {
        return await callOpenAIChat(messages, maxTokens, temperature, options);
    }

    // ٥. وضع nvidia: استخدام NVIDIA NIM مباشرة
    if (options.mode === 'nvidia' && NVIDIA_API_KEY) {
        const result = await callNvidiaNIMChat(messages, maxTokens, temperature, options);
        if (!result.error) return result;
    }

    // ٦. Fallback: Humain إن وُجد مفتاح ولم يُستخدم بعد
    if (HUMAIN_HF_API_KEY) {
        const result = await callHumainChat(messages, maxTokens, temperature, options);
        if (!result.error) return result;
    }

    // ٧. Fallback: NVIDIA NIM إن وُجد مفتاح
    if (NVIDIA_API_KEY && NVIDIA_API_KEY.length > 10) {
        const result = await callNvidiaNIMChat(messages, maxTokens, temperature, options);
        if (!result.error) return result;
    }

    return { error: 'AI_NOT_CONFIGURED' };
}

