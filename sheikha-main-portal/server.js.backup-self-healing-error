// دالة حساب النضج
function computeKnowledgeMaturity(score) {
    const levels = knowledgeSystemsBlueprint.maturityLevels;
    for (let level = 5; level >= 1; level--) {
        const [min, max] = levels[level].range;
        if (score >= min && score <= max) {
            return { level, labelAr: levels[level].label, labelEn: levels[level].labelEn, color: levels[level].color };
        }
    }
    return { level: 1, labelAr: 'ناشئ', labelEn: 'Emerging', color: '#d32f2f' };
}

// دالة حساب الفجوات
function computeKnowledgeBenchmarkGaps(infoScore, researchScore, innovationScore, benchmark) {
    const ref = knowledgeSystemsBlueprint.benchmarks[benchmark] || knowledgeSystemsBlueprint.benchmarks.topUniversities;
    return {
        informationGap: infoScore - ref.information,
        researchGap: researchScore - ref.research,
        innovationGap: innovationScore - ref.innovation,
        overallGap: ((infoScore + researchScore + innovationScore) / 3) - 
                    ((ref.information + ref.research + ref.innovation) / 3),
        benchmarkName: ref.description
    };
}

