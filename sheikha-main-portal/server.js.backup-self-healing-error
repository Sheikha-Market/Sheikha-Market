// ────────────────────────────────────────────────────────────────────────────
// 🛡️ API: سجلات الإصلاح الذاتي
// GET /api/self-healing/logs
// ────────────────────────────────────────────────────────────────────────────
app.get('/api/self-healing/logs', (req, res) => {
    const limit = parseInt(req.query.limit) || 50;
    const status = req.query.status; // filter: detected, fixed, failed, etc.
    
    let logs = selfHealingSystem.logs;
    if (status) {
        logs = logs.filter(log => log.status === status);
    }
    
    res.json({
        success: true,
        data: {
            logs: logs.slice(0, limit),
            total: logs.length,
            filtered: status ? true : false
        },
        message: 'سجلات الإصلاح الذاتي',
        timestamp: new Date().toISOString()
    });
});

