function verifyTokenRole(req) {
    try {
        const authHeader = req.headers.authorization;
        const token = authHeader ? authHeader.replace('Bearer ', '') : null;
        // أيضاً من الكوكيز (مع دعم parsing يدوي عند غياب cookie-parser)
        const cookieHeader = req.headers && req.headers.cookie ? String(req.headers.cookie) : '';
        let parsedCookieToken = null;
        if (cookieHeader) {
            const parts = cookieHeader.split(';');
            for (let i = 0; i < parts.length; i++) {
                const kv = parts[i].trim();
                if (!kv) continue;
                const eq = kv.indexOf('=');
                if (eq <= 0) continue;
                const k = kv.slice(0, eq).trim();
                const v = kv.slice(eq + 1).trim();
                if (k === 'sheikha_token') {
                    parsedCookieToken = decodeURIComponent(v);
                    break;
                }
            }
        }
        const cookieToken =
            req.cookies && req.cookies.sheikha_token
                ? req.cookies.sheikha_token
                : parsedCookieToken;
        // وأيضاً من query (لدعم فتح صفحات الإدارة مباشرة بعد تسجيل الدخول)
        const queryToken = req.query && req.query.token ? String(req.query.token) : null;
        const activeToken = token || cookieToken || queryToken;
        if (!activeToken) return null;
        const decoded = jwt.verify(activeToken, JWT_SECRET);
        return decoded;
    } catch (e) {
        return null;
    }
}

