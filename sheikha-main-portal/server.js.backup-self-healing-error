// ═══════════════════════════════════════════════════════════════════════════════
// ⚠️ Global Error Handler — معالج الأخطاء الآمن مع الإصلاح الذاتي
// ═══════════════════════════════════════════════════════════════════════════════
app.use((err, req, res, _next) => {
    console.error('🔴 خطأ:', {
        message: err.message,
        url: req.originalUrl,
        method: req.method,
        ip: req.ip,
        timestamp: new Date().toISOString()
    });
    
    // تسجيل في نظام الإصلاح الذاتي
    if (typeof selfHealingSystem !== 'undefined' && selfHealingSystem.enabled) {
        let alertType = 'unknown_error';
        const details = {
            message: err.message,
            url: req.originalUrl,
            method: req.method,
            code: err.code
        };
        
        // تحديد نوع التنبيه بناءً على الخطأ
        if (err.code === 'EADDRINUSE') {
            alertType = 'port_conflict';
            details.port = err.port || 8080;
        } else if (err.code === 'MODULE_NOT_FOUND') {
            alertType = 'missing_module';
            details.module = err.message.match(/Cannot find module '(.+?)'/)?.[1];
        } else if (err.code === 'ENOENT') {
            alertType = 'file_not_found';
            details.file = err.path;
        } else if (err.code === 'EACCES' || err.code === 'EPERM') {
            alertType = 'permission_denied';
            details.resource = err.path;
        } else if (err.message.includes('heap') || err.message.includes('memory')) {
            alertType = 'memory_limit';
        }
        
        selfHealingSystem.logAlert(alertType, details);
    }
    
    if (typeof addSystemLog === 'function') addSystemLog('error', 'Server', err.message);
    const statusCode = err.statusCode || err.status || 500;
    res.status(statusCode).json({
        success: false,
        error: 'internal_error',
        message: statusCode === 500 ? 'حدث خطأ في الخادم. يرجى المحاولة لاحقاً.' : err.message,
        selfHealing: typeof selfHealingSystem !== 'undefined' && selfHealingSystem.enabled ? {
            enabled: true,
            message: 'النظام يحاول الإصلاح التلقائي'
        } : undefined,
        timestamp: new Date().toISOString()
    });
});

