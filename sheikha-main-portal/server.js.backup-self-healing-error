let NOTIFICATION_LOG = [];
const MAX_LOG_SIZE = 1000;

function logNotification(type, channel, recipient, status, details = {}) {
    const entry = {
        id: uuidv4(),
        type,
        channel,
        recipient,
        status,
        details,
        timestamp: new Date().toISOString()
    };
    NOTIFICATION_LOG.unshift(entry);
    if (NOTIFICATION_LOG.length > MAX_LOG_SIZE) {
        NOTIFICATION_LOG = NOTIFICATION_LOG.slice(0, MAX_LOG_SIZE);
    }
    return entry;
}

