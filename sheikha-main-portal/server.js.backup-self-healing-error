const malwareScanHost = String(process.env.MALWARE_SCAN_HOST || '127.0.0.1');
const malwareScanPort = Number(process.env.MALWARE_SCAN_PORT || 3310);
const malwareQuarantineDir = path.join(
    __dirname,
