    try {
        const filePath = req.query.path;
        if (!filePath) {
            return res.status(400).json({
                success: false,
                message: 'مسار الملف مطلوب (path parameter)',
                timestamp: new Date().toISOString()
            });
        }

        // حماية: منع الوصول لخارج workspace
        const workspacePath = path.resolve(process.cwd());
        const resolvedPath = path.resolve(filePath);

        if (!resolvedPath.startsWith(workspacePath)) {
            return res.status(403).json({
                success: false,
                message: 'ممنوع الوصول لخارج workspace',
                timestamp: new Date().toISOString()
            });
        }

        // تحقق من وجود الملف
        if (!fs.existsSync(resolvedPath)) {
            return res.status(404).json({
                success: false,
                message: 'الملف غير موجود',
                timestamp: new Date().toISOString()
            });
        }

        // قراءة المحتوى
        const content = fs.readFileSync(resolvedPath, 'utf-8');
        const stats = fs.statSync(resolvedPath);

        res.json({
            success: true,
            data: {
                content,
                path: resolvedPath.replace(workspacePath, ''),
                size: stats.size,
                modified: stats.mtime,
                language: getLanguageFromExtension(resolvedPath)
            },
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في قراءة الملف: ' + error.message,
            timestamp: new Date().toISOString()
        });
    }
