// أفضل من f64 العشوائي — دقة كاملة بلا خسارة كسور
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * توزيع المبالغ بدقة عشرية كاملة بلا خسارة كسور
 * بديل JavaScript الآمن لـ rust_decimal
 */
function preciseDecimal(value, decimals = 2) {
    return Math.round(Number(value) * Math.pow(10, decimals)) / Math.pow(10, decimals);
}

/**
 * حساب توزيع أرباح شرعي دقيق (بديل الدالة المالية في Rust)
 * المبادئ: لا ربا، دقة الوزن والكيل، الصدق في التعامل
 */
function calculateShariaFinancialSplit({
    totalAmount,
    vatRate = 0.15,
    commissionRate = 0,
    reserveRate = 0.02,
    zakatApplicable = false
}) {
    const amount = Number(totalAmount) || 0;
    if (amount <= 0) return { error: 'المبلغ يجب أن يكون أكبر من صفر' };

    const vat = preciseDecimal(amount * vatRate);
    const amountAfterVat = preciseDecimal(amount - vat);
    const commission = preciseDecimal(amountAfterVat * (Number(commissionRate) / 100));
    const reserve = preciseDecimal(amountAfterVat * reserveRate);
    const zakatAmount = zakatApplicable ? preciseDecimal(amountAfterVat * 0.025) : 0;
    const netProfit = preciseDecimal(amountAfterVat - commission - reserve - zakatAmount);
    const checksum = preciseDecimal(vat + amountAfterVat);

    return {
        total: preciseDecimal(amount),
        vat: { amount: vat, rate: vatRate, label: 'ضريبة القيمة المضافة' },
        amountAfterVat,
        commission: { amount: commission, rate: commissionRate, label: 'عمولة المندوب' },
        reserve: { amount: reserve, rate: reserveRate, label: 'احتياطي الطوارئ' },
        zakat: {
            amount: zakatAmount,
            applicable: zakatApplicable,
            label: 'الزكاة الواجبة (٢.٥٪)',
            shariaBasis: 'وَأَقِيمُوا الصَّلَاةَ وَآتُوا الزَّكَاةَ — البقرة ٤٣'
        },
        netProfit,
        checksumValid: checksum === preciseDecimal(amount),
        shariaCompliance: {
            riba: false,
            gharar: false,
            ghish: false,
            label: 'امتثال شرعي كامل — لا ربا لا غرر لا غش'
        },
        quranRef: 'وَأَوْفُوا الْكَيْلَ وَالْمِيزَانَ — الأنعام ١٥٢',
        timestamp: new Date().toISOString()
    };
}

// API الحساب المالي الشرعي الدقيق
app.post(
    '/api/enterprise/financial-split',
    authRequired,
    requireRole(['company', 'admin', 'owner']),
    (req, res) => {
        try {
            const { totalAmount, vatRate, commissionRate, reserveRate, zakatApplicable } = req.body;
            if (!totalAmount || isNaN(Number(totalAmount))) {
                return res
                    .status(400)
                    .json({ success: false, message: 'المبلغ الإجمالي مطلوب وصحيح.' });
            }
            if (Number(commissionRate) < 0 || Number(commissionRate) > 50) {
                return res
                    .status(400)
                    .json({ success: false, message: 'نسبة العمولة يجب أن تكون بين 0 و50.' });
            }
            const result = calculateShariaFinancialSplit({
                totalAmount,
                vatRate,
                commissionRate,
                reserveRate,
                zakatApplicable
            });
            enterpriseGovernanceEngine.appendToChain({
                event: 'financial_split_calculated',
                actor: req.user?.id || 'company',
                data: { totalAmount, netProfit: result.netProfit }
            });
            return res.json({
                success: true,
                data: result,
                message:
                    'تم حساب التوزيع المالي الشرعي الدقيق — وَأَوْفُوا الْكَيْلَ وَالْمِيزَانَ.',
                timestamp: new Date().toISOString()
            });
        } catch (err) {
            return res
                .status(500)
                .json({ success: false, message: 'خطأ في الحساب المالي: ' + err.message });
        }
    }
);

// حاسبة زكاة التجارة والمعادن
app.post('/api/enterprise/zakat-calculator', authRequired, (req, res) => {
    try {
        const { assets = 0, liabilities = 0, nisabGoldGrams = 85 } = req.body;
        const netAssets = preciseDecimal(Number(assets) - Number(liabilities));
        const nisabValueSAR = preciseDecimal(nisabGoldGrams * 300);
        const zakatDue = netAssets >= nisabValueSAR;
        const zakatAmount = zakatDue ? preciseDecimal(netAssets * 0.025) : 0;
        return res.json({
            success: true,
            data: {
                assets: preciseDecimal(assets),
                liabilities: preciseDecimal(liabilities),
                netAssets,
                nisabValueSAR,
                zakatDue,
                zakatAmount,
                zakatRate: '2.5%',
                quranRef: 'وَأَقِيمُوا الصَّلَاةَ وَآتُوا الزَّكَاةَ — البقرة ٤٣',
                message: zakatDue
                    ? 'الزكاة واجبة — طهّر مالك'
                    : 'المال دون النصاب — لا زكاة واجبة حالياً'
            },
            message: 'حاسبة زكاة شيخة — رقمنة بالكتاب والسنة.',
            timestamp: new Date().toISOString()
        });
    } catch (err) {
        return res
            .status(500)
            .json({ success: false, message: 'خطأ في حساب الزكاة: ' + err.message });
    }
});

