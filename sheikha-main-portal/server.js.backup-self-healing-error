        ? process.env.JWT_SECRET
        : FALLBACK_JWT_SECRET;
const PASSWORD_SALT =
    process.env.PASSWORD_SALT && process.env.PASSWORD_SALT.length >= 10
        ? process.env.PASSWORD_SALT
        : 'sheikha-salt-2026-fallback';
const strictSecrets =
