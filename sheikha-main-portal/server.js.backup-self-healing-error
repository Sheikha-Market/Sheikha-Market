                data: { output: out, action: 'doctor' },
                message: 'تم فحص جاهزية البيئة بنجاح',
                timestamp: new Date().toISOString()
            });
        }
        if (action === 'upgrade-devcontainer') {
            const dockerfilePath = path.join(__dirname, '.devcontainer', 'Dockerfile');
            if (!fs.existsSync(dockerfilePath)) {
                return res
                    .status(404)
                    .json({ success: false, message: 'ملف DevContainer غير موجود' });
            }
            let content = fs.readFileSync(dockerfilePath, 'utf8');
            content = content.replace(/javascript-node:\d+/, 'javascript-node:24');
