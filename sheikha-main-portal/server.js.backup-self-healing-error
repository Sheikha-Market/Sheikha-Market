function computeQueueHealthScore() {
    const q = Number((OPERATIONS_STATS && OPERATIONS_STATS.cloudQueueLength) || 0);
    if (q <= 0) return 100;
    if (q <= 20) return 90;
    if (q <= 50) return 80;
    if (q <= 100) return 65;
    if (q <= 250) return 45;
    return 25;
}

function buildSystemIndicesSnapshot() {
    const blockedShariaEvents = AUTH_SESSION_AUDIT.filter(
        e => e && e.event === 'sharia_guard_blocked'
    ).length;
    const unifiedRejectedEvents = AUTH_SESSION_AUDIT.filter(
        e => e && e.type === 'unified_dashboard_rejected'
    ).length;
    const totalShariaFlags = blockedShariaEvents + unifiedRejectedEvents;
    const violationControlScore = Math.max(50, 100 - Math.min(40, totalShariaFlags));

    const nodeHealthScore = 95;
    const throughputScore = Number(OPERATIONS_STATS && OPERATIONS_STATS.totalLogged > 0 ? 90 : 70);
    const queueHealthScore = computeQueueHealthScore();
    const reliabilityScore = Number(CLOUD_SYNC_ENABLED ? 90 : 70);

    const regionsCount = Math.max(1, Number(process.env.SHEIKHA_ACTIVE_REGIONS || 1));
    const multiRegionScore = Math.min(100, 35 + regionsCount * 20);
    const uptimeScore = 95;
    const latencyScore = Number(CLOUD_SYNC_ENABLED ? 85 : 70);

    const governanceContext = {
        policyCoverageScore: 90,
        auditScore: typeof appendAuthSessionAudit === 'function' ? 92 : 70,
        accessControlScore: 90,
        drScore: Number(process.env.SHEIKHA_DR_READY === 'true' ? 90 : 65)
    };

    const researchContext = {
        pipelineScore: Boolean(digitalSeedEngine) ? 88 : 60,
        experimentScore: process.env.SHEIKHA_RD_LAB_ENABLED === 'true' ? 85 : 65,
        productionAdoptionScore: Boolean(plantKnowledgeEngine) ? 82 : 60
    };

    const shariaContext = {
        guardCoverageScore: 95,
        auditTraceScore: typeof appendAuthSessionAudit === 'function' ? 92 : 70,
        violationControlScore
    };

    const status = dashboardServiceLayer.getSystemIndicesStatus({
        compute: { nodeHealthScore, throughputScore, queueHealthScore, reliabilityScore },
        global: { multiRegionScore, uptimeScore, latencyScore },
        governance: governanceContext,
        research: researchContext,
        sharia: shariaContext
    });

    return {
        ...status,
        context: {
            regionsCount,
            cloudSyncEnabled: Boolean(CLOUD_SYNC_ENABLED),
            cloudQueueLength: Number((OPERATIONS_STATS && OPERATIONS_STATS.cloudQueueLength) || 0),
            blockedShariaEvents,
            unifiedRejectedEvents
        },
        generatedAt: new Date().toISOString()
    };
}

