function startListening() {
    const server = app.listen(PORT, '127.0.0.1', () => {
        addSystemLog('success', 'Server', `Server started on port ${PORT}`);
    });

    server.on('error', err => {
        if (err.code === 'EADDRINUSE') {
            console.error(
                `🔴 المنفذ ${PORT} مستخدم — تأكد أن PM2 متوقف وأن systemd هو المسؤول الوحيد`
            );
        } else {
            console.error('🔴 خطأ في بدء الخادم:', err.message);
        }
        process.exit(1);
    });

    server.on('listening', onServerListening);
    global._sheikhaServer = server;

    // ═══════════════════════════════════════════════════════════════════════════════
    // 🔌 WebSocket Server — التحديثات اللحظية
    // ═══════════════════════════════════════════════════════════════════════════════
    const wss = new WebSocket.Server({ server });
    const wsClients = new Set();

    wss.on('connection', ws => {
        wsClients.add(ws);
        console.log('✅ WebSocket client connected — جديد مرتبط');

        ws.on('message', message => {
            try {
                const data = JSON.parse(message);

                // أنماط المراقبة المسموحة
                if (data.action === 'subscribe') {
                    if (data.channel === 'dashboard') {
                        // بث حالة لوحة التحكم
                        broadcastDashboardUpdate(ws);
                    } else if (data.channel === 'erp-scm') {
                        // بث حالة ERP/SCM
                        broadcastERPSCMUpdate(ws);
                    } else if (data.channel === 'shariah-monitor') {
                        // بث حالة التوافق الشرعي
                        broadcastShariahUpdate(ws);
                    } else if (data.channel === 'market-prices') {
                        // بث أسعار السوق
                        broadcastMarketPrices(ws);
                    }
                }
            } catch (e) {
                console.warn('خطأ في معالجة رسالة WebSocket:', e.message);
            }
        });

        ws.on('close', () => {
            wsClients.delete(ws);
            console.log('🔌 WebSocket client disconnected');
        });

        ws.on('error', err => {
            console.error('🔴 خطأ WebSocket:', err.message);
        });
    });

    // دوال البث اللحظي
    function broadcastDashboardUpdate(ws) {
        try {
            if (masterControlCenterInstance) {
                const status = masterControlCenterInstance.getSystemStatus();
                ws.send(
                    JSON.stringify({
                        type: 'dashboard-update',
                        data: status,
                        timestamp: new Date().toISOString()
                    })
                );
            }
        } catch (e) {
            console.warn('خطأ في بث لوحة التحكم:', e.message);
        }
    }

    function broadcastERPSCMUpdate(ws) {
        try {
            if (erpScmInstance) {
                const status = erpScmInstance.getSystemStatus();
                ws.send(
                    JSON.stringify({
                        type: 'erp-scm-update',
                        data: status,
                        timestamp: new Date().toISOString()
                    })
                );
            }
        } catch (e) {
            console.warn('خطأ في بث ERP/SCM:', e.message);
        }
    }

    function broadcastShariahUpdate(ws) {
        try {
            if (erpScmInstance) {
                const report = erpScmInstance.getShariahComplianceReport();
                ws.send(
                    JSON.stringify({
                        type: 'shariah-update',
                        data: report,
                        timestamp: new Date().toISOString()
                    })
                );
            }
        } catch (e) {
            console.warn('خطأ في بث التوافق الشرعي:', e.message);
        }
    }

    function broadcastMarketPrices(ws) {
        try {
            const priceUpdate = {
                gold: 60.5 + Math.random() * 2,
                silver: 0.78 + Math.random() * 0.1,
                copper: 3.85 + Math.random() * 0.2,
                aluminum: 2.1 + Math.random() * 0.1,
                timestamp: new Date().toISOString()
            };
            ws.send(
                JSON.stringify({
                    type: 'market-prices',
                    data: priceUpdate,
                    timestamp: new Date().toISOString()
                })
            );
        } catch (e) {
            console.warn('خطأ في بث الأسعار:', e.message);
        }
    }

    // بث دوري للتحديثات اللحظية (كل 5 ثواني)
    setInterval(() => {
        wsClients.forEach(client => {
            if (client.readyState === WebSocket.OPEN) {
                try {
                    // تحديث أسعار السوق
                    const marketUpdate = {
                        type: 'market-prices-update',
                        data: {
                            gold: 60.5 + Math.random() * 2,
                            silver: 0.78 + Math.random() * 0.1,
                            copper: 3.85 + Math.random() * 0.2,
                            aluminum: 2.1 + Math.random() * 0.1
                        },
                        timestamp: new Date().toISOString()
                    };
                    client.send(JSON.stringify(marketUpdate));
                } catch (e) {
                    // تجاهل الأخطاء
                }
            }
        });
    }, 5000);

    console.log('✅ WebSocket Server — أنظمة البث اللحظي مفعلة');
}

