// Admin file read (for IDE)
app.get('/api/admin/file', authRequired, requireRole(['admin', 'owner']), (req, res) => {
    const filename = req.query.name || req.query.path; // Support both 'name' and 'path'
    if (!filename) return res.status(400).json({ success: false, error: 'اسم الملف مطلوب' });
    const normalized = path.posix.normalize(String(filename).replace(/\\/g, '/'));
    if (
        path.isAbsolute(normalized) ||
        normalized === '..' ||
        normalized.startsWith('../') ||
        normalized.includes('/../')
    ) {
        return res.status(403).json({ success: false, error: 'مسار غير مسموح' });
    }

    // Security: only allow certain file types and paths
    const allowedExtensions = ['.js', '.html', '.css', '.json', '.md', '.txt'];
    const ext = path.extname(normalized).toLowerCase();
    if (!allowedExtensions.includes(ext)) {
        return res.status(403).json({ success: false, error: 'نوع الملف غير مسموح' });
    }

    // Prevent directory traversal (block ..)
    let filePath;

    // Allow paths starting with specific directories
    if (
        normalized.startsWith('public/') ||
        normalized.startsWith('lib/') ||
        normalized.startsWith('data/') ||
        normalized.startsWith('docs/')
    ) {
        filePath = path.join(__dirname, normalized);
    } else if (['server.js', 'package.json'].includes(normalized)) {
        filePath = path.join(__dirname, normalized);
    } else {
        // Default: assume it's in public folder
        filePath = path.join(__dirname, 'public', normalized);
    }

    try {
        if (fs.existsSync(filePath)) {
            const content = fs.readFileSync(filePath, 'utf8');
            res.json({ success: true, filename: normalized, content, size: content.length });
        } else {
            res.status(404).json({ success: false, error: 'الملف غير موجود', path: normalized });
        }
    } catch (e) {
        res.status(500).json({ success: false, error: e.message });
    }
});

