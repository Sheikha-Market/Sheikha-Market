// 🏛️ API: تقييم منظمة دولية
// POST /api/international/organizations-assessment
// Body: { organizationName, organizationType, criteriaScores: {...} }
// ────────────────────────────────────────────────────────────────────────────
app.post('/api/international/organizations-assessment', express.json(), (req, res) => {
    const { organizationName, organizationType, criteriaScores } = req.body;
    
    if (!organizationName || !criteriaScores) {
        return res.status(400).json({
            success: false,
            message: 'يجب تقديم اسم المنظمة ودرجات المعايير',
            timestamp: new Date().toISOString()
        });
    }
    
    const criteria = internationalOrgsBlueprint.assessmentCriteria;
    let total = 0;
    let weightSum = 0;
    
    const assessmentDetails = [];
    
    for (const [key, criterion] of Object.entries(criteria)) {
        const score = clampScore(criteriaScores[key] || 0);
        total += score * criterion.weight;
        weightSum += criterion.weight;
        
        assessmentDetails.push({
            key,
            nameAr: criterion.nameAr,
            score,
            weight: criterion.weight,
            weighted: parseFloat((score * criterion.weight / 100).toFixed(2))
        });
    }
    
    const overallScore = total / weightSum;
    const performance = computeOrgPerformance(overallScore);
    
    // توصيات مخصصة
    const recommendations = [];
    if (criteriaScores.governance < 70) {
        recommendations.push('تطوير آليات الحوكمة والشفافية');
    }
    if (criteriaScores.effectiveness < 70) {
        recommendations.push('تحسين الفعالية التنفيذية وقياس الأثر');
    }
    if (criteriaScores.infrastructure < 70) {
        recommendations.push('تطوير البنية التحتية الرقمية والمادية');
    }
    if (criteriaScores.islamicCompliance < 80) {
        recommendations.push('تعزيز التوافق مع المبادئ الإسلامية (العدل، الشفافية، الشورى)');
    }
    if (performance.level >= 4) {
        recommendations.push('الحفاظ على مستوى التميز والريادة في المجال');
    }
    
    res.json({
        success: true,
        data: {
            organizationName,
            organizationType: organizationType || 'غير محدد',
            overallScore: parseFloat(overallScore.toFixed(2)),
            performance,
            criteriaDetails: assessmentDetails,
            recommendations,
            islamicPerspective: {
                principle: 'المنظمات الدولية يجب أن تُبنى على العدل والشفافية والشورى',
                quranReference: 'وَأَمْرُهُمْ شُورَىٰ بَيْنَهُمْ',
                evaluation: criteriaScores.islamicCompliance >= 75 
                    ? 'توافق جيد مع المبادئ الإسلامية' 
                    : 'يحتاج تحسين التوافق الإسلامي'
            }
        },
        message: 'تم تقييم المنظمة الدولية بنجاح',
        timestamp: new Date().toISOString()
    });
});

