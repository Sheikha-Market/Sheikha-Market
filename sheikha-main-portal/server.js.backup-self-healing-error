        }
    }

    // WebSocket
    const wss = new WebSocket.Server({ server });
    wss.on('connection', (ws, req) => {
        // detect namespace by url
        const url = req.url || '';
        if (url.startsWith('/ws/autopilot')) {
            ws.on('message', async msg => {
                try {
                    const data = JSON.parse(msg);
                    if (!data || !data.text)
                        return ws.send(JSON.stringify({ from: 'system', text: 'الرسالة فارغة' }));

                    // If aiTaskExecutor is available, create a chat task and attempt execution
                    if (aiTaskExecutor && typeof aiTaskExecutor.createTask === 'function') {
                        try {
                            const payload = {
                                type: 'chat',
                                text: String(data.text),
                                meta: { role: data.role || 'user' }
                            };
                            const created = await Promise.resolve(
                                aiTaskExecutor.createTask(payload)
                            );
                            // created may be { success, task } or similar
                            const taskId =
                                (created && created.task && created.task.id) ||
                                (created && created.id) ||
                                null;
                            let execResult = null;
                            if (taskId && typeof aiTaskExecutor.executeTask === 'function') {
                                execResult = await Promise.resolve(
                                    aiTaskExecutor.executeTask(taskId)
                                );
                            } else if (created && created.output) {
                                execResult = created;
                            }

                            const replyText =
                                (execResult &&
                                    (execResult.output?.text ||
                                        execResult.output ||
                                        execResult.message)) ||
                                'تم استلام رسالتك، سأتابع التنفيذ.';
                            ws.send(JSON.stringify({ from: 'ai', text: String(replyText) }));
                        } catch (e) {
                            ws.send(
                                JSON.stringify({
                                    from: 'ai',
                                    text: 'خطأ داخلي أثناء معالجة الذكاء الاصطناعي'
                                })
                            );
                        }
                    } else {
                        // Fallback echo behaviour
                        ws.send(JSON.stringify({ from: 'ai', text: `تلقّيت: ${data.text}` }));
                    }
                } catch (e) {
                    ws.send(JSON.stringify({ from: 'system', text: 'خطأ في الرسالة' }));
                }
            });
            ws.send(JSON.stringify({ from: 'system', text: 'مرحباً بك في شات التطوير' }));
        } else {
            // default behavior (prices/iot)
            _wsClients.push(ws);
            ws.send(JSON.stringify({ type: 'connected', prices: LIVE_PRICES }));
            ws.send(
                JSON.stringify({
                    type: 'iotSensors',
                    sensors: IOT_SENSORS,
                    timestamp: new Date().toISOString()
                })
            );
            ws.on('close', () => {
                _wsClients = _wsClients.filter(c => c !== ws);
            });
        }
    });

    console.log(`
