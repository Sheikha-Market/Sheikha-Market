        // حفظ الوكيل المُفعّل في قاعدة البيانات
        const agentsDir = path.join(__dirname, 'data', 'construction-agents');
        if (!fs.existsSync(agentsDir)) {
            fs.mkdirSync(agentsDir, { recursive: true });
        }

        const activationRecord = {
            agentId: activatedAgent.agentId,
            nameAr: activatedAgent.nameAr,
            status: 'ACTIVE',
            activatedAt: activatedAgent.activatedAt,
            config: activatedAgent.config,
            responsibilities: activatedAgent.responsibilities,
            subAgents: activatedAgent.subAgents
        };

        const recordFile = path.join(agentsDir, `${agentId}-activated.json`);
        fs.writeFileSync(recordFile, JSON.stringify(activationRecord, null, 2));

        res.json({
            success: true,
            message: 'تم تفعيل الوكيل بنجاح',
            data: activatedAgent,
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في تفعيل الوكيل: ' + error.message,
            timestamp: new Date().toISOString()
        });
    }
});

// 🔥 تفعيل جميع وكلاء البناء والتطوير (التفعيل الشامل)
app.post('/api/construction-agents/activate-all', express.json(), async (req, res) => {
    try {
        const { config, projectName } = req.body;

        const allAgents = ConstructionAgentsEngine.getAllConstructionAgents();
        const activatedAgents = [];
        const errors = [];

        for (const agent of allAgents) {
            try {
                const activated = ConstructionAgentsEngine.activateAgent(agent.id, {
                    ...config,
                    projectName: projectName || 'مشروع متكامل',
                    activationTime: new Date().toISOString()
                });
                activatedAgents.push(activated);

                // حفظ السجل
                const agentsDir = path.join(__dirname, 'data', 'construction-agents');
                if (!fs.existsSync(agentsDir)) {
                    fs.mkdirSync(agentsDir, { recursive: true });
                }

                const recordFile = path.join(agentsDir, `${agent.id}-activated.json`);
                fs.writeFileSync(
                    recordFile,
                    JSON.stringify(
                        {
                            agentId: activated.agentId,
                            nameAr: activated.nameAr,
                            role: activated.role,
                            status: 'ACTIVE',
                            activatedAt: activated.activatedAt,
                            projectName: projectName || 'مشروع متكامل'
                        },
                        null,
                        2
                    )
                );
            } catch (e) {
                errors.push({
                    agentId: agent.id,
                    error: e.message
                });
            }
        }

        res.json({
            success: true,
            message: `تم تفعيل ${activatedAgents.length}/${allAgents.length} وكيل`,
            data: {
                summary: {
                    totalActivated: activatedAgents.length,
                    totalFailed: errors.length,
                    projectName: projectName || 'مشروع متكامل',
                    activationTime: new Date().toISOString()
                },
                activatedAgents: activatedAgents.map(a => ({
                    id: a.agentId,
                    nameAr: a.nameAr,
                    role: a.role,
                    status: a.status,
                    responsibilities: a.responsibilities
                })),
                errors
            },
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في تفعيل الوكلاء: ' + error.message,
            timestamp: new Date().toISOString()
        });
    }
});

