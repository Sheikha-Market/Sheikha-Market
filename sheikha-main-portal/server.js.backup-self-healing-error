function isHttpsRequest(req) {
    try {
        if (req && req.secure) return true;
        const xf = req && req.headers ? String(req.headers['x-forwarded-proto'] || '') : '';
        const proto = xf.split(',')[0].trim().toLowerCase();
        return proto === 'https';
    } catch (_) {
        return false;
    }
}

function setSheikhaTokenCookie(req, res, token) {
    try {
        if (!token) return;
        const sevenDaysMs = 7 * 24 * 60 * 60 * 1000;
        const secure = isHttpsRequest(req);
        const baseOpts = { path: '/', maxAge: sevenDaysMs, sameSite: 'lax', secure };

        // Host-only cookie
        res.cookie('sheikha_token', String(token), baseOpts);

        // Root domain cookie for subdomain sharing (www / non-www)
        const host = String((req && req.hostname) || '').toLowerCase();
        if (host === 'sheikha.top' || host.endsWith('.sheikha.top')) {
            res.cookie('sheikha_token', String(token), { ...baseOpts, domain: '.sheikha.top' });
        }
    } catch (_) {}
}

