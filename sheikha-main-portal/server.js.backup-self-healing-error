// 🔍 IDE API: البحث في الملفات
app.post('/api/ide/search', express.json(), (req, res) => {
    try {
        const { query, path: searchPath } = req.body;

        if (!query) {
            return res.status(400).json({
                success: false,
                message: 'query مطلوب',
                timestamp: new Date().toISOString()
            });
        }

        const workspacePath = path.resolve(process.cwd());
        const targetPath = searchPath ? path.resolve(searchPath) : workspacePath;

        if (!targetPath.startsWith(workspacePath)) {
            return res.status(403).json({
                success: false,
                message: 'ممنوع الوصول لخارج workspace',
                timestamp: new Date().toISOString()
            });
        }

        // بحث بسيط (سيُحسّن لاحقاً بـ ripgrep أو ag)
        const results = [];

        function searchInDirectory(dir) {
            const items = fs.readdirSync(dir, { withFileTypes: true });

            for (const item of items) {
                const fullPath = path.join(dir, item.name);

                // تخطي المجلدات المخفية والنظام
                if (
                    item.name.startsWith('.') ||
                    item.name === 'node_modules' ||
                    item.name === 'dist' ||
                    item.name === 'build'
                ) {
                    continue;
                }

                if (item.isDirectory()) {
                    searchInDirectory(fullPath);
                } else {
                    try {
                        const content = fs.readFileSync(fullPath, 'utf-8');
                        const lines = content.split('\n');

                        lines.forEach((line, index) => {
                            if (line.toLowerCase().includes(query.toLowerCase())) {
                                results.push({
                                    file: fullPath.replace(workspacePath, ''),
                                    line: index + 1,
                                    content: line.trim()
                                });
                            }
                        });
                    } catch (e) {
                        // تخطي الملفات الثنائية
                    }
                }
            }
        }

        searchInDirectory(targetPath);

        res.json({
            success: true,
            data: {
                query,
                results: results.slice(0, 100), // أول 100 نتيجة
                total: results.length
            },
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في البحث: ' + error.message,
            timestamp: new Date().toISOString()
        });
    }
});

