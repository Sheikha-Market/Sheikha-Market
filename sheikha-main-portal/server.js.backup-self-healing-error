function scanFileWithClamAV(filePath) {
    return new Promise(resolve => {
        if (!malwareScanEnabled)
            return resolve({ scanned: false, clean: true, reason: 'disabled' });
        if (!fs.existsSync(filePath))
            return resolve({ scanned: false, clean: false, reason: 'missing_file' });
        const socket = net.createConnection(
            { host: malwareScanHost, port: malwareScanPort },
            () => {
                socket.write(`SCAN ${filePath}\n`);
            }
        );
        let response = '';
        socket.setTimeout(6000);
        socket.on('data', chunk => {
            response += chunk.toString('utf8');
        });
        socket.on('timeout', () => socket.destroy(new Error('timeout')));
        socket.on('error', err => resolve({ scanned: false, clean: false, reason: err.message }));
        socket.on('end', () => {
            const clean = /OK$/m.test(response) && !/FOUND$/m.test(response);
            if (!clean) {
                try {
                    fs.mkdirSync(malwareQuarantineDir, { recursive: true });
                    const safeName = path.basename(filePath);
                    fs.renameSync(filePath, path.join(malwareQuarantineDir, safeName));
                } catch (_) {}
            }
            resolve({ scanned: true, clean, response: response.trim() });
        });
    });
}

async function scanUploadsDirectory() {
    if (!malwareScanEnabled) return;
    const uploadsDir = path.join(__dirname, 'uploads');
    try {
        if (!fs.existsSync(uploadsDir)) return;
        const files = fs.readdirSync(uploadsDir).map(f => path.join(uploadsDir, f));
        for (const filePath of files) {
            const stat = fs.statSync(filePath);
            if (!stat.isFile()) continue;
            const result = await scanFileWithClamAV(filePath);
            if (!result.clean) {
                securityLog('malware_scan_alert', { filePath, result });
            }
        }
    } catch (e) {
        securityLog('malware_scan_error', { message: e.message });
    }
}
