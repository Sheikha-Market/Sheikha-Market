const SUBSCRIPTION_LIMITS = {
    starter: 5,
    business: 12,
    enterprise: 24
};

function normalizeList(value) {
    if (!value) return [];
    if (Array.isArray(value))
        return value
            .map(v =>
                String(v || '')
                    .trim()
                    .toLowerCase()
            )
            .filter(Boolean);
    return String(value)
        .split(',')
        .map(v =>
            String(v || '')
                .trim()
                .toLowerCase()
        )
        .filter(Boolean);
}

function normalizeAccessScope(value) {
    const s = String(value || '')
        .trim()
        .toLowerCase();
    if (!s) return 'full';
    if (['full', 'enterprise', 'business', 'commercial'].includes(s)) return 'full';
    if (
        [
            'learning-community',
            'learn-community',
            'community-learning',
            'learning',
            'education',
            'community'
        ].includes(s)
    ) {
        return 'learning-community';
    }
    return 'full';
}

function buildOrganizationBlueprint(input = {}) {
    const sector = String(input.sector || input.organizationType || 'commerce')
        .trim()
        .toLowerCase();
    const goals = normalizeList(input.goals);
    const requestedModules = normalizeList(input.modules);
    const subscription = String(input.subscription || 'starter')
        .trim()
        .toLowerCase();
    const accessScope = normalizeAccessScope(
        input.accessScope || input.usageMode || input.userIntent
    );
    const rolesBreakdown =
        input.rolesBreakdown && typeof input.rolesBreakdown === 'object'
            ? input.rolesBreakdown
            : {};
    const teamSize = Number(input.teamSize || input.usersCount || 1) || 1;
    const managersCount = Number(input.managersCount || rolesBreakdown.managers || 1) || 1;

    const presetKey = sector.includes('gov')
        ? 'government'
        : accessScope === 'learning-community'
          ? 'learning_community'
          : sector.includes('logistics') || sector.includes('supply')
            ? 'logistics'
            : sector.includes('company') ||
                sector.includes('enterprise') ||
                sector.includes('institution')
              ? 'enterprise'
              : 'commerce';
    const preset = ORG_PRESET_BLUEPRINTS[presetKey];

    const modulesSet = new Set(preset.modules);
    if (accessScope === 'learning-community') {
        modulesSet.clear();
        modulesSet.add('education');
        modulesSet.add('community');
        modulesSet.add('support');
        modulesSet.add('sharia');
    } else {
        requestedModules.forEach(m => {
            if (ENTERPRISE_MODULE_CATALOG[m]) modulesSet.add(m);
        });
    }
    if (goals.some(g => g.includes('compliance') || g.includes('امتثال')))
        modulesSet.add('compliance');
    if (goals.some(g => g.includes('finance') || g.includes('مالي'))) modulesSet.add('finance');
    if (goals.some(g => g.includes('logistics') || g.includes('لوجست')))
        modulesSet.add('logistics');
    if (goals.some(g => g.includes('تعليم') || g.includes('education') || g.includes('learn')))
        modulesSet.add('education');
    if (goals.some(g => g.includes('community') || g.includes('مجتمع')))
        modulesSet.add('community');
    modulesSet.add('sharia');

    const tier = ['enterprise', 'business', 'starter'].includes(subscription)
        ? subscription
        : 'starter';
    const maxModules = SUBSCRIPTION_LIMITS[tier];
    const selectedModules = Array.from(modulesSet).slice(0, maxModules);

    const workspace = {
        sector: presetKey,
        teamSize,
        managersCount,
        departmentHeads: Number(rolesBreakdown.departmentManagers || 0),
        drivers: Number(rolesBreakdown.drivers || 0),
        accountingUsers: Number(rolesBreakdown.accountants || 0),
        subscriptionTier: tier,
        accessScope
    };

    return {
        presetKey,
        dashboard: preset.dashboard,
        appProfile: preset.appProfile,
        modules: selectedModules,
        workspace,
        rolePolicies: ORG_ROLE_POLICIES
    };
}

