            // التشخيص
            alert.diagnostic = await rule.diagnostic(alert.details);
            console.log(`📋 [Self-Healing] التشخيص:`, alert.diagnostic);
            
            // الإصلاح
            alert.status = 'fixing';
            console.log(`🔧 [Self-Healing] تطبيق الإصلاح...`);
            alert.fix = await rule.fix(alert.details);
            
            if (alert.fix.success) {
                alert.status = 'fixed';
                this.stats.autoFixed++;
                console.log(`✅ [Self-Healing] تم الإصلاح: ${alert.fix.message}`);
            } else {
                alert.status = 'fix_failed';
                this.stats.failedFixes++;
                console.log(`⚠️ [Self-Healing] فشل الإصلاح: ${alert.fix.message}`);
            }
        } catch (e) {
            alert.status = 'error';
            alert.error = e.message;
            this.stats.failedFixes++;
            console.error(`❌ [Self-Healing] خطأ في الإصلاح:`, e);
        }
    }
};

