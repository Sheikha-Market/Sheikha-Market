function getBaseUrl(req) {
    const base = process.env.BASE_URL;
    if (base) return base.replace(/\/$/, '');
    const proto = req.get('x-forwarded-proto') || req.protocol || 'http';
    const host = req.get('x-forwarded-host') || req.get('host') || 'localhost:8080';
    return proto + '://' + host;
}
function findOrCreateOAuthUser(provider, providerId, profile) {
    let user = USERS.find(
        u => u.provider === provider && String(u.providerId) === String(providerId)
    );
    const email = (profile.email || '').trim().toLowerCase().slice(0, 200);
    const adminEmail = String(ADMIN_EMAIL || '')
        .trim()
        .toLowerCase();
    if (user) {
        // Ensure admin email always resolves to admin role
        if (email && adminEmail && email === adminEmail) user.role = 'admin';
        else if (!user.role) user.role = 'user';
        if (email && !user.email) user.email = email;
        saveJSON(USERS_FILE, USERS);
        return user;
    }

    // Link OAuth login to existing account by email (important for admin login via Google)
    if (email) {
        const byEmail = USERS.find(
            u =>
                String(u.email || '')
                    .trim()
                    .toLowerCase() === email
        );
        if (byEmail) {
            byEmail.provider = provider;
            byEmail.providerId = providerId;
            byEmail.oauthProviders = byEmail.oauthProviders || {};
            byEmail.oauthProviders[provider] = {
                providerId: String(providerId),
                linkedAt: new Date().toISOString()
            };
            if (email === adminEmail) byEmail.role = 'admin';
            else if (!byEmail.role) byEmail.role = 'user';
            byEmail.updatedAt = new Date().toISOString();
            saveJSON(USERS_FILE, USERS);
            return byEmail;
        }
    }

    const id = uuidv4();
    const spec = getSpecialty('metals_trader');
    const name = (profile.name || profile.email || providerId).trim().slice(0, 120);
    const role = email && adminEmail && email === adminEmail ? 'admin' : 'user';
    user = {
        id,
        provider,
        providerId,
        phone: '',
        passwordHash: '',
        name,
        email,
        storeName: spec.storeLabel || name,
        region: '',
        marketingEnabled: false,
        specialty: spec.id,
        role,
        oauthProviders: {
            [provider]: { providerId: String(providerId), linkedAt: new Date().toISOString() }
        },
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
    };
    USERS.push(user);
    saveJSON(USERS_FILE, USERS);
    const trader = {
        id,
        name: user.name,
        email: user.email,
        phone: user.phone,
        region: user.region,
        company: user.storeName,
        specialty: spec.id,
        specialtyLabel: spec.nameAr,
        createdAt: user.createdAt
    };
    if (!TRADERS.find(t => t.id === id)) {
        TRADERS.push(trader);
        saveJSON(TRADERS_FILE, TRADERS);
    }
    return user;
}
function redirectWithToken(res, baseUrl, token, error, role) {
    const qs = new URLSearchParams();
    if (error) {
        qs.set('error', String(error));
    } else if (token) {
        qs.set('token', String(token));
        if (role) qs.set('role', String(role));
    }
    const query = qs.toString();
    const target = baseUrl + '/تسجيل-الدخول.html' + (query ? '?' + query : '');
    res.redirect(302, target);
}

