// دالة حساب النضج
function computeInfrastructureMaturity(score) {
    const levels = infrastructureAnalysisBlueprint.maturityLevels;
    for (let level = 5; level >= 1; level--) {
        const [min, max] = levels[level].range;
        if (score >= min && score <= max) {
            return { level, labelAr: levels[level].label, labelEn: levels[level].labelEn, color: levels[level].color };
        }
    }
    return { level: 1, labelAr: 'بدائي', labelEn: 'Initial', color: '#d32f2f' };
}

// دالة حساب الفجوات مع المعايير المرجعية
function computeInfrastructureBenchmarkGaps(digitalScore, physicalScore, benchmark) {
    const ref = infrastructureAnalysisBlueprint.benchmarks[benchmark] || infrastructureAnalysisBlueprint.benchmarks.globalLeaders;
    return {
        digitalGap: digitalScore - ref.digital,
        physicalGap: physicalScore - ref.physical,
        overallGap: ((digitalScore + physicalScore) / 2) - ((ref.digital + ref.physical) / 2),
        benchmarkName: ref.description
    };
}

