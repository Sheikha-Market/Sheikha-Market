// 🔁 LMM API: Provider Switch — تغيير مزود الذكاء لحظياً
const LMM_PROVIDER_ADMIN_KEY =
    process.env.LMM_PROVIDER_ADMIN_KEY ||
    process.env.SHEIKHA_LMM_ADMIN_KEY ||
    process.env.JWT_SECRET ||
    '';

function getLMMProviderRequestKey(req) {
    const headerKey = req.headers['x-lmm-admin-key'];
    if (headerKey && String(headerKey).trim()) {
        return String(headerKey).trim();
    }

    const authHeader = req.headers.authorization || '';
    if (authHeader.startsWith('Bearer ')) {
        return authHeader.slice(7).trim();
    }

    return '';
}

function isValidLMMProviderAdminKey(req) {
    const incoming = getLMMProviderRequestKey(req);
    if (!LMM_PROVIDER_ADMIN_KEY || !incoming) {
        return false;
    }

    try {
        return crypto.timingSafeEqual(Buffer.from(incoming), Buffer.from(LMM_PROVIDER_ADMIN_KEY));
    } catch (_) {
        return false;
    }
}

app.post('/api/lmm/provider', express.json(), (req, res) => {
    try {
        if (!LMM_PROVIDER_ADMIN_KEY) {
            return res.status(503).json({
                success: false,
                message: 'مفتاح إدارة LMM غير مُعدّ على الخادم',
                timestamp: new Date().toISOString()
            });
        }

        if (!isValidLMMProviderAdminKey(req)) {
            return res.status(401).json({
                success: false,
                message: 'غير مصرح — مفتاح إدارة LMM مطلوب',
                timestamp: new Date().toISOString()
            });
        }

        const { provider } = req.body || {};

        if (!provider) {
            return res.status(400).json({
                success: false,
                message: 'provider مطلوب (openai | claude | mock)',
                timestamp: new Date().toISOString()
            });
        }

        const result = sheikhaLMM.setProvider(provider);

        if (!result.success) {
            return res.status(400).json({
                success: false,
                message: result.message,
                data: {
                    provider: result.provider,
                    realProviderActive: result.realProviderActive
                },
                timestamp: new Date().toISOString()
            });
        }

        return res.json({
            success: true,
            message: result.message,
            data: {
                provider: result.provider,
                realProviderActive: result.realProviderActive,
                available: sheikhaLMM.getAvailableProviders()
            },
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        return res.status(500).json({
            success: false,
            message: 'خطأ في تغيير المزود: ' + error.message,
            timestamp: new Date().toISOString()
        });
    }
});

