    console.log('      GET  /api/ai-core/production/metrics — مقاييس الإنتاج');
    console.log('      GET  /api/ai-core/production/health — صحة النظام');
    console.log('      GET  /api/ai-core/capabilities — القدرات الكاملة');
    console.log('      GET  /api/ai-core/status — حالة المحركات');
} catch (e) {
    console.warn('⚠️ [AI-Core] لم يتم تحميل منظومة RAG/Agents:', e.message);
    // نسخة احتياطية لمسارات model-integrations حتى تعمل لوحة الأدمن
    const modelRegPath = path.join(__dirname, 'data', 'ai-model-integrations.json');
    const loadReg = () => {
        try {
            if (!fs.existsSync(modelRegPath)) {
                const s = { integrations: [], lastRefreshedAt: null };
                fs.writeFileSync(modelRegPath, JSON.stringify(s, null, 2), 'utf8');
                return s;
            }
            const r = JSON.parse(fs.readFileSync(modelRegPath, 'utf8') || '{}');
            if (!Array.isArray(r.integrations)) r.integrations = [];
            return r;
        } catch (_) {
            return { integrations: [] };
        }
    };
    app.get('/api/ai-core/model-integrations', (req, res) =>
        res.json({
            success: true,
            data: { ...loadReg(), recommendations: {} },
            message: 'تم جلب سجل التكاملات',
            timestamp: new Date().toISOString()
        })
    );
    app.post('/api/ai-core/model-integrations', express.json(), (req, res) => {
        const { name, provider, model } = req.body || {};
        if (!name || !provider || !model)
            return res
                .status(400)
                .json({ success: false, message: 'الحقول المطلوبة: name, provider, model' });
        const reg = loadReg();
        const id = `${String(provider).toLowerCase()}-${Date.now()}`;
        reg.integrations.push({
            id,
            name,
            provider,
            model,
            active: false,
            autoUpgrade: true,
            createdAt: new Date().toISOString(),
            updatedAt: new Date().toISOString()
        });
        fs.writeFileSync(modelRegPath, JSON.stringify(reg, null, 2), 'utf8');
        return res.json({
            success: true,
            data: { id },
            message: 'تمت الإضافة',
            timestamp: new Date().toISOString()
        });
    });
    app.patch('/api/ai-core/model-integrations/:id', express.json(), (req, res) => {
        const id = String(req.params.id || '');
        const { active } = req.body || {};
        const reg = loadReg();
        const t = reg.integrations.find(i => i.id === id);
        if (!t) return res.status(404).json({ success: false, message: 'النموذج غير موجود' });
        if (typeof active === 'boolean') t.active = active;
        t.updatedAt = new Date().toISOString();
        fs.writeFileSync(modelRegPath, JSON.stringify(reg, null, 2), 'utf8');
        return res.json({
            success: true,
            data: t,
            message: 'تم التحديث',
            timestamp: new Date().toISOString()
        });
    });
    app.post('/api/ai-core/model-integrations/auto-refresh', express.json(), (req, res) => {
        const reg = loadReg();
        reg.lastRefreshedAt = new Date().toISOString();
        fs.writeFileSync(modelRegPath, JSON.stringify(reg, null, 2), 'utf8');
        return res.json({
            success: true,
            data: { upgradedCount: 0, lastRefreshedAt: reg.lastRefreshedAt },
            message: 'تم التحديث',
            timestamp: new Date().toISOString()
        });
    });
    console.log('   📡 [احتياطي] GET/POST/PATCH /api/ai-core/model-integrations — مُفعّل');
}

