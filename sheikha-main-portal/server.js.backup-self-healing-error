            category: 'innovation',
            titleAr: 'تعزيز النظام الابتكاري',
            actions: [
                'بناء ثقافة ابتكار مؤسسية',
                'إنشاء حاضنات ومسرعات أعمال',
                'تطوير سلسلة ابتكار كاملة',
                'حماية الملكية الفكرية'
            ]
        });
    }
    
    // توصيات التكامل
    const maxGap = Math.max(
        Math.abs(infoScore - researchScore),
        Math.abs(researchScore - innovationScore),
        Math.abs(infoScore - innovationScore)
    );
    
    if (maxGap > 15) {
        recommendations.push({
            priority: 'high',
            category: 'integration',
            titleAr: 'تحقيق التوازن بين الأنظمة',
            actions: [
                'ربط النظم المعلوماتية بالبحث والابتكار',
                'إنشاء منصة موحدة للمعرفة',
                'تطبيق نموذج Innovation Loop',
                'دمج البيانات والبحث والتطوير'
            ],
            maxGap: maxGap.toFixed(1)
        });
    }
    
    if (maturityLevel >= 4) {
        recommendations.push({
            priority: 'strategic',
            category: 'excellence',
            titleAr: 'الريادة العالمية',
            actions: [
                'نشر المعرفة عالمياً (Open Science)',
                'قيادة التعاون البحثي الدولي',
                'إنشاء مراكز تميز متخصصة',
                'تصدير الابتكارات والتقنيات'
            ]
        });
    }
    
    // توصية إسلامية
    recommendations.push({
        priority: 'foundational',
        category: 'islamic',
        titleAr: 'التوافق الإسلامي',
        actions: [
            'توجيه البحث لخدمة المجتمع',
            'الالتزام بأخلاقيات البحث الإسلامية',
            'تطوير ابتكارات حلال',
            'مشاركة المعرفة (طلب العلم فريضة)'
        ]
    });
    
    return recommendations;
}

// دالة خارطة الطريق
function buildKnowledgeRoadmap(infoScore, researchScore, innovationScore) {
    const roadmap = {
        phase1: {
            titleAr: 'المرحلة الأولى: البناء (0-12 شهر)',
            focus: 'بناء الأساس والبنية التحتية',
            initiatives: []
        },
        phase2: {
            titleAr: 'المرحلة الثانية: التكامل (12-24 شهر)',
            focus: 'ربط الأنظمة وتحقيق التآزر',
            initiatives: []
        },
        phase3: {
            titleAr: 'المرحلة الثالثة: الريادة (24-36 شهر)',
            focus: 'التميز والريادة العالمية',
            initiatives: []
        }
    };
    
    if (infoScore < 60) {
        roadmap.phase1.initiatives.push('بناء نظام معلومات مؤسسي متكامل');
        roadmap.phase2.initiatives.push('تطبيق ذكاء الأعمال المتقدم');
    } else if (infoScore < 80) {
        roadmap.phase1.initiatives.push('تحسين جودة البيانات وحوكمتها');
        roadmap.phase2.initiatives.push('دمج الذكاء الاصطناعي في النظم');
    }
    
    if (researchScore < 60) {
        roadmap.phase1.initiatives.push('تطوير البنية البحثية الأساسية');
        roadmap.phase2.initiatives.push('بناء شراكات بحثية استراتيجية');
    } else if (researchScore < 80) {
        roadmap.phase1.initiatives.push('رفع جودة المخرجات البحثية');
        roadmap.phase2.initiatives.push('التوسع في البحوث متعددة التخصصات');
    }
    
    if (innovationScore < 60) {
        roadmap.phase1.initiatives.push('إنشاء منظومة ابتكار مؤسسية');
        roadmap.phase2.initiatives.push('تطوير سلسلة ابتكار كاملة');
    } else if (innovationScore < 80) {
        roadmap.phase1.initiatives.push('تسريع التسويق التجاري للابتكارات');
        roadmap.phase2.initiatives.push('بناء نظام بيئي للابتكار');
    }
    
    roadmap.phase3.initiatives.push('الريادة في المعرفة والابتكار إقليمياً');
    roadmap.phase3.initiatives.push('المساهمة في حل التحديات العالمية');
    roadmap.phase3.initiatives.push('نشر نموذج شيخة للمعرفة والابتكار');
    
    return roadmap;
}

