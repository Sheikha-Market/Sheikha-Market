// تسجيل مبكر لمسارات NVIDIA/CUDA لضمان توفرها دائمًا
app.get('/api/cuda/verify', (req, res) => {
    const { execFile } = require('child_process');
    const scriptPath = path.join(__dirname, 'scripts', 'cuda-verify.py');
    const pythonPaths = [
        process.env.SHEIKHA_CUDA_PYTHON,
        process.env.SHEIKHA_VENV_PYTHON,
        process.env.HOME ? path.join(process.env.HOME, 'codex', 'venv', 'bin', 'python3') : null,
        process.env.HOME ? path.join(process.env.HOME, 'codex', 'venv', 'bin', 'python') : null,
        'python3',
        'python'
    ].filter(Boolean);
    let lastErr = null;
    const tryNext = i => {
        if (i >= pythonPaths.length) {
            return res.json({
                success: false,
                data: {
                    cuda_available: false,
                    error: lastErr || 'لم يتم العثور على Python مع torch'
                },
                timestamp: new Date().toISOString()
            });
        }
        const py = pythonPaths[i];
        execFile(py, [scriptPath], { timeout: 10000, maxBuffer: 5120 }, (err, stdout, stderr) => {
            const rawOutput = (stdout || (err && err.stdout) || '').toString().trim();
            if (err && !rawOutput) {
                lastErr = err.message || stderr;
                return tryNext(i + 1);
            }
            try {
                const data = JSON.parse(rawOutput || '{}');
                res.json({
                    success: true,
                    data: {
                        cuda_available: !!data.cuda_available,
                        torch_version: data.torch_version,
                        cuda_version: data.cuda_version,
                        device_name: data.device_name,
                        device_count: data.device_count || 0,
                        error: data.error
                    },
                    timestamp: new Date().toISOString()
                });
            } catch (e) {
                if (err) {
                    lastErr = err.message || stderr || e.message;
                    return tryNext(i + 1);
                }
                res.json({
                    success: false,
                    data: { cuda_available: false, error: rawOutput || e.message },
                    timestamp: new Date().toISOString()
                });
            }
        });
    };
    if (!fs.existsSync(scriptPath)) {
        return res.json({
            success: false,
            data: { cuda_available: false, error: 'سكربت التحقق غير موجود' },
            timestamp: new Date().toISOString()
        });
    }
    tryNext(0);
});

app.get('/api/nvidia-cuda/capabilities', async (req, res) => {
    try {
        const nvidiaPath = path.join(__dirname, 'data', 'nvidia-sheikha-integration-catalog.json');
        const cudaPath = path.join(__dirname, 'data', 'cuda-sheikha-integration-catalog.json');
        const planPath = path.join(__dirname, 'data', 'nvidia-cuda-sheikha-integration-plan.json');
        const nvidia = fs.existsSync(nvidiaPath)
            ? JSON.parse(fs.readFileSync(nvidiaPath, 'utf8'))
            : null;
        const cuda = fs.existsSync(cudaPath) ? JSON.parse(fs.readFileSync(cudaPath, 'utf8')) : null;
        const plan = fs.existsSync(planPath) ? JSON.parse(fs.readFileSync(planPath, 'utf8')) : null;

        let cudaVerify = null;
        try {
            const { execFile } = require('child_process');
            const scriptPath = path.join(__dirname, 'scripts', 'cuda-verify.py');
            const py =
                process.env.SHEIKHA_CUDA_PYTHON ||
                process.env.SHEIKHA_VENV_PYTHON ||
                (process.env.HOME
                    ? path.join(process.env.HOME, 'codex', 'venv', 'bin', 'python3')
                    : null) ||
                'python3';
            if (fs.existsSync(scriptPath)) {
                const { promisify } = require('util');
                const execFileAsync = promisify(execFile);
                try {
                    const { stdout } = await execFileAsync(py, [scriptPath], {
                        timeout: 8000,
                        maxBuffer: 5120
                    });
                    cudaVerify = JSON.parse((stdout || '').trim() || '{}');
                } catch (execErr) {
                    const rawOutput = (execErr && execErr.stdout ? execErr.stdout : '').toString().trim();
                    if (rawOutput) {
                        cudaVerify = JSON.parse(rawOutput || '{}');
                    }
                }
            }
        } catch (_) {}

        const status = {
            nvidiaNim: !!(process.env.NVIDIA_API_KEY && process.env.NVIDIA_API_KEY.length > 10),
            cudaToolkit: cudaVerify?.cuda_available
                ? `مفعّل ✓ — ${cudaVerify.device_name || 'GPU'} (PyTorch ${
                      cudaVerify.torch_version || ''
                  })`
                : 'جاهزية — pip install torch --index-url https://download.pytorch.org/whl/cu121',
            cudaAvailable: !!cudaVerify?.cuda_available,
            cudaDevice: cudaVerify?.device_name || null,
            cudaDeviceCount: cudaVerify?.device_count || 0
        };

        res.json({
            success: true,
            data: {
                nvidia,
                cuda,
                plan,
                status,
                cudaVerify: cudaVerify || null,
                apis: {
                    nvidia: '/api/nvidia/integration-catalog',
                    cuda: '/api/cuda/integration-catalog',
                    cudaVerify: '/api/cuda/verify',
                    plan: '/api/nvidia-cuda/integration-plan',
                    architecture: '/api/sheikha/architecture-superior'
                }
            },
            timestamp: new Date().toISOString()
        });
    } catch (e) {
        res.json({ success: false, message: e.message });
    }
});

