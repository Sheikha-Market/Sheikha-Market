// 🔬 API: تقييم النظم المعرفية
// POST /api/knowledge-systems/assessment
// Body: { entityName, informationScores: {...}, researchScores: {...}, innovationScores: {...}, benchmarkTarget }
// ────────────────────────────────────────────────────────────────────────────
app.post('/api/knowledge-systems/assessment', express.json(), (req, res) => {
    const { entityName, informationScores, researchScores, innovationScores, benchmarkTarget } = req.body;
    
    if (!entityName || !informationScores || !researchScores || !innovationScores) {
        return res.status(400).json({
            success: false,
            message: 'يجب تقديم اسم الكيان ودرجات جميع الأنظمة (معلوماتية، بحثية، ابتكارية)',
            timestamp: new Date().toISOString()
        });
    }
    
    // حساب النظم المعلوماتية
    const infoDomains = knowledgeSystemsBlueprint.informationSystems.domains;
    let infoTotal = 0;
    let infoWeightSum = 0;
    
    for (const [key, domain] of Object.entries(infoDomains)) {
        const score = clampScore(informationScores[key] || 0);
        infoTotal += score * domain.weight;
        infoWeightSum += domain.weight;
    }
    const infoOverall = infoTotal / infoWeightSum;
    
    // حساب النظم البحثية
    const researchDomains = knowledgeSystemsBlueprint.researchSystems.domains;
    let researchTotal = 0;
    let researchWeightSum = 0;
    
    for (const [key, domain] of Object.entries(researchDomains)) {
        const score = clampScore(researchScores[key] || 0);
        researchTotal += score * domain.weight;
        researchWeightSum += domain.weight;
    }
    const researchOverall = researchTotal / researchWeightSum;
    
    // حساب النظم الابتكارية
    const innovationDomains = knowledgeSystemsBlueprint.innovationSystems.domains;
    let innovationTotal = 0;
    let innovationWeightSum = 0;
    
    for (const [key, domain] of Object.entries(innovationDomains)) {
        const score = clampScore(innovationScores[key] || 0);
        innovationTotal += score * domain.weight;
        innovationWeightSum += domain.weight;
    }
    const innovationOverall = innovationTotal / innovationWeightSum;
    
    // الدرجة الشاملة (35% معلوماتية + 35% بحثية + 30% ابتكارية)
    const overallScore = (
        infoOverall * 0.35 +
        researchOverall * 0.35 +
        innovationOverall * 0.30
    );
    
    // النضج
    const maturity = computeKnowledgeMaturity(overallScore);
    
    // المقارنة المرجعية
    const gaps = computeKnowledgeBenchmarkGaps(
        infoOverall,
        researchOverall,
        innovationOverall,
        benchmarkTarget || 'topUniversities'
    );
    
    // التوصيات
    const recommendations = buildKnowledgeRecommendations(
        infoOverall,
        researchOverall,
        innovationOverall,
        maturity.level
    );
    
    // خارطة الطريق
    const roadmap = buildKnowledgeRoadmap(infoOverall, researchOverall, innovationOverall);
    
    res.json({
        success: true,
        data: {
            entityName,
            assessment: {
                information: {
                    overall: parseFloat(infoOverall.toFixed(2)),
                    maturity: computeKnowledgeMaturity(infoOverall),
                    domains: Object.entries(infoDomains).map(([key, domain]) => ({
                        key,
                        nameAr: domain.nameAr,
                        score: clampScore(informationScores[key] || 0),
                        weight: domain.weight
                    }))
                },
                research: {
                    overall: parseFloat(researchOverall.toFixed(2)),
                    maturity: computeKnowledgeMaturity(researchOverall),
                    domains: Object.entries(researchDomains).map(([key, domain]) => ({
                        key,
                        nameAr: domain.nameAr,
                        score: clampScore(researchScores[key] || 0),
                        weight: domain.weight
                    }))
                },
                innovation: {
                    overall: parseFloat(innovationOverall.toFixed(2)),
                    maturity: computeKnowledgeMaturity(innovationOverall),
                    domains: Object.entries(innovationDomains).map(([key, domain]) => ({
                        key,
                        nameAr: domain.nameAr,
                        score: clampScore(innovationScores[key] || 0),
                        weight: domain.weight
                    }))
                },
                overall: parseFloat(overallScore.toFixed(2)),
                maturity
            },
            comparison: {
                benchmarkTarget: benchmarkTarget || 'topUniversities',
                gaps
            },
            roadmap,
            recommendations,
            islamicGuidance: {
                foundation: knowledgeSystemsBlueprint.quranAndSunnahFoundation,
                principle: 'طلب العلم فريضة، والابتكار عبادة، ونشر المعرفة صدقة جارية',
                operatingRule: 'البحث بإتقان، والابتكار بأمانة، والمعرفة للجميع'
            }
        },
        message: 'تم تحليل النظم المعلوماتية والبحثية والابتكارية بنجاح',
        timestamp: new Date().toISOString()
    });
});

