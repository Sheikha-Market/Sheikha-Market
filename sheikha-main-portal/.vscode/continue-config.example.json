{
  "//": [
    "بسم الله — إعداد Continue لـ VS Code × Ollama × Azure",
    "انسخ هذا الملف إلى: ~/.continue/config.json",
    "أو: %APPDATA%\\Continue\\config.json على Windows",
    "بعد نسخه، غيّر apiBase ليشمل IP الـ Azure VM الخاص بك"
  ],
  "models": [
    {
      "title": "شيخة كودكس — Llama 3.1 (Azure VM)",
      "provider": "ollama",
      "model": "llama3.1:8b",
      "apiBase": "REPLACE_WITH_OLLAMA_AZURE_ENDPOINT",
      "contextLength": 8192,
      "completionOptions": {
        "temperature": 0.3,
        "topP": 0.9,
        "maxTokens": 2048
      }
    },
    {
      "title": "شيخة كودكس — Qwen 2.5 14B (قوي)",
      "provider": "ollama",
      "model": "qwen2.5:14b",
      "apiBase": "REPLACE_WITH_OLLAMA_AZURE_ENDPOINT",
      "contextLength": 16384,
      "completionOptions": {
        "temperature": 0.2,
        "topP": 0.9,
        "maxTokens": 4096
      }
    },
    {
      "title": "شيخة كودكس — Phi-3 Mini (سريع)",
      "provider": "ollama",
      "model": "phi3:mini",
      "apiBase": "REPLACE_WITH_OLLAMA_AZURE_ENDPOINT",
      "contextLength": 4096,
      "completionOptions": {
        "temperature": 0.4,
        "topP": 0.95,
        "maxTokens": 1024
      }
    },
    {
      "title": "محلي — Llama 3.1 (localhost)",
      "provider": "ollama",
      "model": "llama3.1:8b",
      "apiBase": "http://localhost:11434",
      "contextLength": 8192
    }
  ],
  "tabAutocompleteModel": {
    "title": "Tab Autocomplete — Phi-3 Mini",
    "provider": "ollama",
    "model": "phi3:mini",
    "apiBase": "REPLACE_WITH_OLLAMA_AZURE_ENDPOINT"
  },
  "allowAnonymousTelemetry": false,
  "slashCommands": [
    {
      "name": "edit",
      "description": "تعديل الكود المحدد"
    },
    {
      "name": "comment",
      "description": "إضافة شرح للكود"
    },
    {
      "name": "share",
      "description": "مشاركة المحادثة"
    }
  ],
  "customCommands": [
    {
      "name": "sheikha-review",
      "prompt": "راجع هذا الكود كمطوّر خبير في منظومة سوق شيخة. ركّز على: الأمان، الأداء، وجودة الكود.",
      "description": "مراجعة كود شيخة"
    }
  ],
  "contextProviders": [
    { "name": "code" },
    { "name": "docs" },
    { "name": "diff" },
    { "name": "terminal" },
    { "name": "open" },
    { "name": "tree" }
  ],
  "rules": [
    "أنت مساعد كود سيادي لمنظومة سوق شيخة.",
    "استخدم العربية للشرح والتعليقات عند الطلب.",
    "التزم بمبادئ: لا ضرر ولا ضرار، الأمان أولاً، الكود واضح ومُختبر.",
    "دائماً اقترح التحسينات من منظور الأداء والأمان."
  ]
}
