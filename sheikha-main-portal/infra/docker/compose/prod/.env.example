# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit the .env file — it is listed in .gitignore.
#
# Quick start:
#   cp .env.example .env
#   # Replace all CHANGE_ME values, then:
#   docker compose build main-portal   # build app image locally (no ghcr.io login needed)
#   docker compose up -d nginx postgres redis main-portal
#
# To also start the MCP server (requires ghcr.io/sheikha/mcp-server access):
#   COMPOSE_PROFILES=mcp docker compose up -d

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sheikha
POSTGRES_USER=sheikha
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Main-portal / MCP-server (Node.js) ───────────────────────────────────────
# Database connection (used by the Node app)
# Note: the ${VAR} placeholders below are expanded by docker compose at runtime
# using the values set above in this file — they are NOT shell-expanded when you
# copy the file. After copying to .env, you may also write the full URL directly.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379

# JWT / session secret — must be at least 32 characters
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string

# Password hashing salt — must be at least 10 characters (REQUIRED — app exits without it)
# Generate: openssl rand -base64 24
PASSWORD_SALT=CHANGE_ME_at_least_10_chars_salt

# Application public URL
APP_PUBLIC_URL=https://public.sheikha.top
APP_ADMIN_URL=https://admin.sheikha.top
