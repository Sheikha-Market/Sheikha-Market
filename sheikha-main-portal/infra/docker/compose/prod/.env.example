# ══════════════════════════════════════════════════════════════════════════════
#  SHEIKHA MARKET — Production Environment Variables Template
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية قبل تشغيل docker compose
#
#  ⚡ تفعيل سريع (يُولّد أسراراً عشوائية تلقائياً):
#     bash setup-env.sh
#
#  يدوياً:
#     cp .env.example .env
#     # استبدل جميع قيم CHANGE_ME، ثم:
#     docker compose build main-portal
#     docker compose up -d nginx postgres redis main-portal
#
#  لتشغيل MCP server أيضاً (يتطلب صلاحية ghcr.io/sheikha/mcp-server):
#     COMPOSE_PROFILES=mcp docker compose up -d
#
#  ⚠️  لا ترفع ملف .env إلى Git — محمي تلقائياً في .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sheikha
POSTGRES_USER=sheikha
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Main-portal / MCP-server (Node.js) ───────────────────────────────────────
# Database connection (used by the Node app)
# Note: the ${VAR} placeholders below are expanded by docker compose at runtime
# using the values set above in this file — they are NOT shell-expanded when you
# copy the file. After copying to .env, you may also write the full URL directly.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379

# JWT / session secret — REQUIRED — يجب أن يكون ≥ 32 حرفاً (app exits without it)
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string

# Password hashing salt — REQUIRED — يجب أن يكون ≥ 10 أحرف (app exits without it)
# Generate: openssl rand -base64 24
# ⚠️  احفظ هذه القيمة — تغييرها يُبطل جميع كلمات المرور المخزّنة
PASSWORD_SALT=CHANGE_ME_at_least_10_chars_salt

# Application public URL
APP_PUBLIC_URL=https://public.sheikha.top
APP_ADMIN_URL=https://admin.sheikha.top
