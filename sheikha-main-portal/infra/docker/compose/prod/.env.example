# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit the .env file — it is listed in .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sheikha
POSTGRES_USER=sheikha
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Main-portal / MCP-server (Node.js) ───────────────────────────────────────
# Database connection (used by the Node app)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379

# JWT / session secret
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string

# Application public URL
APP_PUBLIC_URL=https://public.sheikha.top
APP_ADMIN_URL=https://admin.sheikha.top
