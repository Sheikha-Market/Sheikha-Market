{
    "core": "sheikha-production-core",
    "version": "1.0.0",
    "title": "نواة الإنتاج لمنصة شيخة",
    "description": "منظومة الإنتاج الكاملة — نشر + مراقبة + ترقية + تكامل مستمر — حلال وآمن",
    "owner": "سلمان أحمد بن سلمان الراجح",
    "activatedAt": "2026-03-13",
    "governancePolicy": "quran-and-sunnah",

    "productionReadiness": {
        "gate": "training-core + simulation-testing-core must pass before production",
        "minimumTestPassRate": 98,
        "minimumEvaluationScore": 90,
        "shariaComplianceRequired": true,
        "rollbackCapability": true
    },

    "deploymentBlueprint": {
        "target": "vercel-primary + backup-node",
        "strategy": "blue-green",
        "healthCheckEndpoint": "/api/health",
        "rollbackTrigger": "error-rate > 1% OR sharia-violation-detected",
        "deploymentSteps": [
            "pre-deployment smoke test",
            "sharia compliance gate",
            "database migration check",
            "dependency integrity check",
            "blue-green swap",
            "post-deployment health verification"
        ],
        "environments": [
            {
                "id": "development",
                "nameAr": "التطوير",
                "url": "localhost:8080",
                "dataStrategy": "synthetic-safe-data"
            },
            {
                "id": "staging",
                "nameAr": "التجهيز",
                "url": "staging.sheikha.top",
                "dataStrategy": "isolated-real-data-subset"
            },
            {
                "id": "production",
                "nameAr": "الإنتاج",
                "url": "https://sheikha.top",
                "dataStrategy": "full-live-data"
            }
        ]
    },

    "healthMonitoring": {
        "enabled": true,
        "checkIntervalSeconds": 30,
        "endpoints": [
            {"path": "/api/health", "critical": true},
            {"path": "/api/sheikha-ai/generative-rag", "critical": true},
            {"path": "/api/sheikha-ai/quranic-science", "critical": false},
            {"path": "/api/sheikha-ai/training", "critical": false},
            {"path": "/api/sheikha-ai/simulation", "critical": false}
        ],
        "alertThresholds": {
            "responseTimeMs": 3000,
            "errorRatePercent": 1,
            "uptimeMinimumPercent": 99.9
        },
        "shariaMonitoring": {
            "enabled": true,
            "checkPattern": "monitor-for-sharia-violations-in-outputs",
            "autoBlockOnViolation": true
        }
    },

    "autoScaling": {
        "enabled": true,
        "minInstances": 1,
        "maxInstances": 10,
        "scaleTrigger": "cpu > 70% OR memory > 80% OR rps > 40",
        "halalLoadBalancing": {
            "strategy": "least-connections",
            "healthGating": true,
            "fairDistribution": true
        }
    },

    "continuousIntegration": {
        "pipeline": ["lint", "unit-tests", "sharia-compliance-check", "integration-tests", "simulation-run", "staging-deploy", "regression-suite", "production-promote"],
        "blockOnFailure": true,
        "notifyOwner": true
    },

    "disasterRecovery": {
        "backupFrequency": "daily",
        "backupRetentionDays": 30,
        "rpo": "1 hour",
        "rto": "4 hours",
        "geographicRedundancy": "GCC-region-first"
    },

    "productionGovernance": {
        "auditLogging": true,
        "immutableAuditTrail": true,
        "changeControlRequired": true,
        "ownerApprovalRequired": true,
        "shariaReviewOnMajorChange": true,
        "zeroToleranceViolations": ["riba-detection", "fraud-detection", "privacy-breach", "data-tampering"]
    }
}
