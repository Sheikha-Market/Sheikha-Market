# ══════════════════════════════════════════════════════════════════════════════
#  SHEIKHA MARKET — Environment Variables Template
#  انسخ هذا الملف إلى .env وأضف القيم الحقيقية
#  cp .env.example .env
#
#  ⚠️  لا ترفع ملف .env إلى GitHub — محمي تلقائياً في .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
BASE_URL=https://sheikha-market.com
LOG_LEVEL=info
CORS_ORIGIN=https://sheikha-market.com

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET
PASSWORD_SALT=REPLACE_WITH_A_STRONG_RANDOM_SALT
DATA_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_KEY
DATA_ENCRYPTION_KEY_HEX=REPLACE_WITH_HEX_KEY
DATA_ENCRYPTION_KEY_VERSION=1
DATA_ENCRYPTION_ALGORITHM=aes-256-gcm
SECURITY_ENFORCE_HTTPS=true
SECURITY_HSTS_ENABLED=true
SECURITY_STRICT_SECRETS=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_SECRET_ACCESS_KEY
AWS_REGION=me-south-1
AWS_ACCOUNT_ID=REPLACE_WITH_YOUR_ACCOUNT_ID

# ─── S3 ───────────────────────────────────────────────────────────────────────
SHEIKHA_S3_BUCKET=sheikha-market-uploads

# ─── SES (البريد الإلكتروني) ──────────────────────────────────────────────────
SES_FROM_EMAIL=no-reply@sheikha-market.com

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_ENABLED=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=REPLACE_WITH_EMAIL_USER
EMAIL_PASS=REPLACE_WITH_EMAIL_PASSWORD

# ─── SMS ──────────────────────────────────────────────────────────────────────
SMS_ENABLED=false
SMS_PROVIDER=twilio

# ─── OpenAI / Codex ───────────────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY
AI_MODE=openai
AI_LLM_MODEL=gpt-5.2
AI_LLM_BASE_URL=https://api.openai.com/v1

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-opus-4-6-20260205
CLAUDE_MAX_TOKENS=8192
CLAUDE_EXTENDED_CONTEXT=true
CLAUDE_CONTEXT_COMPACTION=true
CLAUDE_ADAPTIVE_THINKING=true

# ─── HUMAIN (SDAIA) ───────────────────────────────────────────────────────────
HUMAIN_API_KEY=REPLACE_WITH_YOUR_HUMAIN_KEY
HUMAIN_BASE_URL=https://api-inference.huggingface.co
HUMAIN_MODEL=humain-ai/ALLaM-7B-Instruct-preview
HUMAIN_MAX_TOKENS=4096

# ─── HuggingFace ──────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=REPLACE_WITH_YOUR_HF_KEY

# ─── NVIDIA ───────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=REPLACE_WITH_YOUR_NVIDIA_KEY

# ─── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_STRONG_MODEL=qwen2.5:14b
OLLAMA_LIGHT_MODEL=phi3:mini
OLLAMA_PROFILE=standard
OLLAMA_ALLOW_PULL=false
OLLAMA_AUTO_UPDATE=false
OLLAMA_TIMEOUT_MS=60000
OLLAMA_UPDATE_INTERVAL_HOURS=24

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_API_VERSION=2023-10-16

# ─── Google Cloud / OAuth ─────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=REPLACE_WITH_YOUR_PROJECT_ID
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_GOOGLE_CLIENT_SECRET

# ─── Social Login ─────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=REPLACE_WITH_YOUR_APPLE_CLIENT_ID
APPLE_CLIENT_SECRET=REPLACE_WITH_YOUR_APPLE_CLIENT_SECRET
MICROSOFT_CLIENT_ID=REPLACE_WITH_YOUR_MS_CLIENT_ID
MICROSOFT_CLIENT_SECRET=REPLACE_WITH_YOUR_MS_CLIENT_SECRET
TWITTER_CLIENT_ID=REPLACE_WITH_YOUR_TWITTER_CLIENT_ID
TWITTER_CLIENT_SECRET=REPLACE_WITH_YOUR_TWITTER_CLIENT_SECRET
INSTAGRAM_CLIENT_ID=REPLACE_WITH_YOUR_INSTAGRAM_CLIENT_ID
INSTAGRAM_CLIENT_SECRET=REPLACE_WITH_YOUR_INSTAGRAM_CLIENT_SECRET
SNAPCHAT_CLIENT_ID=REPLACE_WITH_YOUR_SNAPCHAT_CLIENT_ID
SNAPCHAT_CLIENT_SECRET=REPLACE_WITH_YOUR_SNAPCHAT_CLIENT_SECRET
TIKTOK_CLIENT_ID=REPLACE_WITH_YOUR_TIKTOK_CLIENT_ID
TIKTOK_CLIENT_SECRET=REPLACE_WITH_YOUR_TIKTOK_CLIENT_SECRET

# ─── نافذ (هوية سعودية) ───────────────────────────────────────────────────────
NAFATH_CLIENT_ID=REPLACE_WITH_YOUR_NAFATH_CLIENT_ID
NAFATH_CLIENT_SECRET=REPLACE_WITH_YOUR_NAFATH_CLIENT_SECRET
NAFATH_AUTH_URL=https://nafath.api.iam.sa/oauth2/authorize
NAFATH_TOKEN_URL=https://nafath.api.iam.sa/oauth2/token
NAFATH_USERINFO_URL=https://nafath.api.iam.sa/oauth2/userinfo

# ─── Third-party APIs ─────────────────────────────────────────────────────────
PEXELS_API_KEY=REPLACE_WITH_YOUR_PEXELS_KEY
FIGMA_ACCESS_TOKEN=REPLACE_WITH_YOUR_FIGMA_TOKEN
LINEAR_API_KEY=REPLACE_WITH_YOUR_LINEAR_KEY
RAMP_API_KEY=REPLACE_WITH_YOUR_RAMP_KEY
DROPBOX_SIGN_API_KEY=REPLACE_WITH_YOUR_DROPBOX_SIGN_KEY
ADOBE_CLIENT_ID=REPLACE_WITH_YOUR_ADOBE_CLIENT_ID
ADOBE_CLIENT_SECRET=REPLACE_WITH_YOUR_ADOBE_CLIENT_SECRET

# ─── Sentry (مراقبة الأخطاء) ──────────────────────────────────────────────────
SENTRY_DSN=REPLACE_WITH_YOUR_SENTRY_DSN

# ─── Cloud Sync ───────────────────────────────────────────────────────────────
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_URL=https://sync.sheikha-market.com

# ─── Malware Scan ─────────────────────────────────────────────────────────────
MALWARE_SCAN_ENABLED=false
MALWARE_SCAN_HOST=localhost
MALWARE_SCAN_PORT=3310
MALWARE_SCAN_QUARANTINE_DIR=/tmp/quarantine

# ─── Admin (بيانات المدير) ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@sheikha-market.com
ADMIN_RECOVERY_EMAIL=recovery@sheikha-market.com
ADMIN_SECONDARY_EMAIL=secondary@sheikha-market.com
ADMIN_PHONE=REPLACE_WITH_ADMIN_PHONE
ADMIN_OWNER_NAME=REPLACE_WITH_OWNER_NAME
ADMIN_NATIONAL_ID=REPLACE_WITH_NATIONAL_ID
ADMIN_BIRTH_YEAR_HIJRI=REPLACE_WITH_BIRTH_YEAR_HIJRI
ADMIN_BUSINESS_NAME=سوق شيخة
ADMIN_BUSINESS_REGISTRY=REPLACE_WITH_CR_NUMBER
ADMIN_UNIFIED_NUMBER=REPLACE_WITH_UNIFIED_NUMBER
ADMIN_NAFATH_BUSINESS_ID=REPLACE_WITH_NAFATH_BUSINESS_ID
ADMIN_CR_ISSUE_DATE=REPLACE_WITH_CR_ISSUE_DATE
ADMIN_CR_EXPIRY_DATE=REPLACE_WITH_CR_EXPIRY_DATE
ADMIN_CR_REFERENCE=REPLACE_WITH_CR_REFERENCE
ADMIN_ADDRESS=REPLACE_WITH_ADDRESS
ADMIN_POSTAL_CODE=REPLACE_WITH_POSTAL_CODE
ADMIN_CAPITAL=REPLACE_WITH_CAPITAL_AMOUNT

# ─── Operations ───────────────────────────────────────────────────────────────
OPERATIONS_ESSENTIAL_VALUE_THRESHOLD=1000

# ─── Meta AI — Sheikha Meta (CAPI + WhatsApp + Pixel + Commerce) ──────────────
# احصل على هذه القيم من: business.facebook.com → Meta Business Manager
# الإعدادات الأساسية ─────────────────────────────────────────────────────────
META_PIXEL_ID=REPLACE_WITH_PIXEL_ID
META_ACCESS_TOKEN=REPLACE_WITH_SYSTEM_USER_ACCESS_TOKEN
META_APP_ID=REPLACE_WITH_APP_ID
META_GRAPH_VERSION=v21.0
META_TEST_EVENT_CODE=TEST12345
META_WA_VERIFY_TOKEN=sheikha_verify

# WhatsApp Business API ───────────────────────────────────────────────────────
META_WHATSAPP_TOKEN=REPLACE_WITH_WHATSAPP_TOKEN
META_WA_PHONE_ID=REPLACE_WITH_PHONE_NUMBER_ID
META_WABA_ID=REPLACE_WITH_WABA_ID

# بيكسلات الأسواق الخمسة — Multi-Market Pixels ───────────────────────────────
# أنشئ بيكسل منفصل لكل سوق في: Events Manager → ربط مصدر بيانات → ويب
META_PIXEL_ID_METALS=REPLACE_WITH_METALS_PIXEL_ID
META_PIXEL_ID_SCRAP=REPLACE_WITH_SCRAP_PIXEL_ID
META_PIXEL_ID_PRECIOUS=REPLACE_WITH_PRECIOUS_PIXEL_ID
META_PIXEL_ID_RARE=REPLACE_WITH_RARE_PIXEL_ID
META_PIXEL_ID_NOW=REPLACE_WITH_NOW_PIXEL_ID

# رموز الوصول لكل سوق — اختياري (إذا فارغ يستخدم META_ACCESS_TOKEN)
META_ACCESS_TOKEN_METALS=
META_ACCESS_TOKEN_SCRAP=
META_ACCESS_TOKEN_PRECIOUS=
META_ACCESS_TOKEN_RARE=
META_ACCESS_TOKEN_NOW=

# Conversions API — توكن مخصص للـ CAPI (يُنشأ من: Business Settings → مستخدمو النظام)
# هذا التوكن مختلف عن META_ACCESS_TOKEN — يُستخدم فقط لإرسال أحداث CAPI
META_CAPI_ACCESS_TOKEN=REPLACE_WITH_CAPI_SYSTEM_USER_TOKEN

# حساب الإعلانات والكتالوجات ─────────────────────────────────────────────────
# META_AD_ACCOUNT_ID: من Meta Ads Manager — شكله: act_XXXXXXXXXXXXXXXXX
META_AD_ACCOUNT_ID=REPLACE_WITH_AD_ACCOUNT_ID
# META_CATALOG_ID: من Commerce Manager → الكتالوج → الإعدادات → معرّف الكتالوج
META_CATALOG_ID=REPLACE_WITH_CATALOG_ID
META_CATALOG_TEST_ID=REPLACE_WITH_CATALOG_TEST_ID

# تشغيل الإرسال الفعلي لـ Meta Graph API ─────────────────────────────────────
# false = وضع التطوير (يحفظ محلياً فقط، لا يرسل لـ Meta)
# true  = وضع الإنتاج (يرسل الأحداث فعلياً لـ Meta Conversions API)
META_AUTOMATION_APPROVED=false

# خادم الخلفية ───────────────────────────────────────────────────────────────
META_BACKGROUND_PORT=8085

# توكنات CAPI الإقليمية — Regional CAPI Tokens (Geo-Routing) ──────────────────
# كل توكن System User مخصص لمنطقة لضمان الامتثال القانوني:
#   SA/GCC  → PDPL (نظام حماية البيانات الشخصية — السعودية)
#   Europe  → GDPR (اللائحة الأوروبية لحماية البيانات)
#   Americas→ CCPA (قانون خصوصية المستهلك — كاليفورنيا)
# إذا فارغ → يُستخدم META_CAPI_ACCESS_TOKEN كاحتياطي لكل المناطق
META_CAPI_TOKEN_SA_GCC=REPLACE_WITH_SA_GCC_SYSTEM_USER_TOKEN
META_CAPI_TOKEN_EUROPE=REPLACE_WITH_EUROPE_SYSTEM_USER_TOKEN
META_CAPI_TOKEN_AMERICAS=REPLACE_WITH_AMERICAS_SYSTEM_USER_TOKEN
META_CAPI_TOKEN_ASIA=REPLACE_WITH_ASIA_SYSTEM_USER_TOKEN

# أرقام هاتف واتساب لكل سوق — Per-Market WhatsApp Phone Number IDs ──────────
# أنشئ رقماً منفصلاً لكل سوق في: Meta Business Manager → WhatsApp → Phone Numbers
# كل رقم يستقبل رسائل العملاء بالسوق المناسب ويرجع أحداث CAPI تلقائياً
# إذا فارغ → يُستخدم META_WA_PHONE_ID كاحتياطي
META_WA_PHONE_ID_METALS=REPLACE_WITH_METALS_WA_PHONE_NUMBER_ID
META_WA_PHONE_ID_SCRAP=REPLACE_WITH_SCRAP_WA_PHONE_NUMBER_ID
META_WA_PHONE_ID_PRECIOUS=REPLACE_WITH_PRECIOUS_WA_PHONE_NUMBER_ID
META_WA_PHONE_ID_RARE=REPLACE_WITH_RARE_WA_PHONE_NUMBER_ID
META_WA_PHONE_ID_NOW=REPLACE_WITH_NOW_WA_PHONE_NUMBER_ID
# أرقام أوروبية — EU WhatsApp Numbers (GDPR-compliant, EU-hosted via Unifonic or 360dialog)
META_WA_PHONE_ID_EU_IT=REPLACE_WITH_ITALY_WA_PHONE_NUMBER_ID      # +39 إيطاليا
META_WA_PHONE_ID_EU_DE=REPLACE_WITH_GERMANY_WA_PHONE_NUMBER_ID    # +49 ألمانيا
META_WA_PHONE_ID_EU_FR=REPLACE_WITH_FRANCE_WA_PHONE_NUMBER_ID     # +33 فرنسا

# البوابة الخارجية — External CAPI Gateway (capig.datah04.com)
# هذه البوابة تم تفعيلها مسبقاً وتم ربطها بالبيكسل 4383900581880844
META_EXTERNAL_GATEWAY_URL=https://capig.datah04.com
META_EXTERNAL_GATEWAY_EU_URL=https://capig-eu.datah04.com          # (مستقبلاً) سيرفر فرانكفورت GDPR

# عتبات الإنذارات — Alert Thresholds ─────────────────────────────────────────
# يُرسل تنبيه تلقائي عبر /api/شيخة-ميتا/kpi/تنبيهات لو نزلت المقاييس تحتها
META_ALERT_MIN_EMQ=6.0            # أدنى Event Match Quality (0-10) — دون 6 يرفع تكاليف الإعلان
META_ALERT_MAX_DEDUP=0.30         # أعلى معدل تكرار (0.0-1.0) — فوق 30% يعني خلل في Deduplication
META_ALERT_MIN_WA_DELIVERY=0.90   # أدنى معدل تسليم واتساب (0.0-1.0)

# حوكمة — Governance ──────────────────────────────────────────────────────────
META_AUDIT_LOG_SIZE=500           # حجم سجل التدقيق في الذاكرة (يُدار تلقائياً)

# ERP Integration ──────────────────────────────────────────────────────────────
# كم ساعة بين كل مزامنة تلقائية لعقود الـ ERP مع Meta Offline Conversions API
META_ERP_SYNC_INTERVAL_HOURS=6

# KPI — تقدير تكلفة الحدث للحسابات المبدئية (يُستبدل ببيانات Ads API الفعلية)
META_KPI_COST_PER_EVENT=15        # تكلفة الحدث التقديرية بالريال السعودي
