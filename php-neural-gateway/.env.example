# ══════════════════════════════════════════════════════════════════════════════
#  SHEIKHA PHP Neural Gateway — Environment Variables Template
#  انسخ هذا الملف إلى .env وأضف القيم الحقيقية
#  cp .env.example .env
#
#  ⚠️  لا ترفع ملف .env إلى GitHub — محمي تلقائياً في .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
PORT=8090
LOG_LEVEL=INFO

# ─── Security ─────────────────────────────────────────────────────────────────
# JWT_SECRET يجب أن يكون 32 حرفاً على الأقل — 32+ chars required
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_32CHARS_MINIMUM

# ─── Node.js Integration ──────────────────────────────────────────────────────
# عنوان خادم Node.js الرئيسي — sheikha-main-portal
NODE_API_URL=http://localhost:8080

# مهلة الطلبات بالثواني — request timeout in seconds
NODE_TIMEOUT=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# * للسماح لكل النطاقات (للتطوير فقط)
# أو حدد نطاقاً واحداً: https://sheikha-market.com
CORS_ORIGIN=https://sheikha-market.com
